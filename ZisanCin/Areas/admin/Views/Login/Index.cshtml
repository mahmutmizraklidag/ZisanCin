@model LoginVm
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yönetim Paneli | Giriş</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --primary-color: #4361ee;
            --bg-gradient: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
        }

        body {
            background: #f4f7fe;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow: hidden;
        }

        /* Arka Plan Dekorasyonu */
        .bg-circle {
            position: absolute;
            border-radius: 50%;
            background: var(--bg-gradient);
            filter: blur(80px);
            opacity: 0.15;
            z-index: -1;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
        }

        .login-box {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            padding: 3rem;
            border-radius: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.4);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
        }

        .brand-logo {
            width: 60px;
            height: 60px;
            background: var(--bg-gradient);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            box-shadow: 0 10px 20px rgba(67, 97, 238, 0.3);
        }

        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #4a5568;
            margin-bottom: 8px;
        }

        .form-control {
            border-radius: 12px;
            padding: 12px 16px;
            border: 1px solid #e2e8f0;
            background: #fff;
            font-size: 0.95rem;
            transition: all 0.3s;
        }

            .form-control:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 4px rgba(67, 97, 238, 0.1);
            }

        .btn-login {
            background: var(--bg-gradient);
            border: none;
            border-radius: 12px;
            padding: 12px;
            font-weight: 700;
            letter-spacing: 0.5px;
            margin-top: 1rem;
            transition: all 0.3s;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 15px rgba(67, 97, 238, 0.3);
            }

        .input-group-text {
            background: transparent;
            border-left: none;
            cursor: pointer;
            color: #a0aec0;
        }

        .validation-summary ul {
            list-style: none;
            padding: 0;
            margin: 0;
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

    <div class="bg-circle" style="width: 400px; height: 400px; top: -100px; right: -100px;"></div>
    <div class="bg-circle" style="width: 300px; height: 300px; bottom: -50px; left: -50px;"></div>

    <div class="login-container">
        <div class="login-box">
            <div class="brand-logo">
                <i class="bi bi-shield-lock-fill text-white fs-3"></i>
            </div>

            <h3 class="text-center fw-bold text-dark mb-1">Hoş Geldiniz</h3>
            <p class="text-center text-muted small mb-4">Devam etmek için lütfen giriş yapın.</p>

            <form asp-action="index">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 validation-summary">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="mb-3">
                    <label class="form-label">Kullanıcı Adı</label>
                    <div class="input-group">
                        <input asp-for="Username" type="text" class="form-control" placeholder="admin" required>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Şifre</label>
                    <div class="input-group">
                        <input asp-for="Password" type="password" class="form-control" id="password" placeholder="••••••••" required>
                        <span class="input-group-text border-start-0 bg-white" id="togglePassword">
                            <i class="bi bi-eye"></i>
                        </span>
                    </div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-login">
                        Sisteme Giriş Yap <i class="bi bi-arrow-right-short ms-1"></i>
                    </button>
                </div>
            </form>

            <div class="mt-4 text-center">
                <p class="small text-muted mb-0">&copy; 2026 Tüm Hakları Saklıdır.</p>
                <p class="fw-bold small text-primary">Admin Panel v3.0</p>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        $(document).ready(function() {
            $('#togglePassword').on('click', function() {
                const passwordInput = $('#password');
                const icon = $(this).find('i');

                if (passwordInput.attr('type') === 'password') {
                    passwordInput.attr('type', 'text');
                    icon.removeClass('bi-eye').addClass('bi-eye-slash');
                } else {
                    passwordInput.attr('type', 'password');
                    icon.removeClass('bi-eye-slash').addClass('bi-eye');
                }
            });
        });
    </script>

</body>
</html>