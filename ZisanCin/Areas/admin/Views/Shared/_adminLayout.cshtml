<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ZisanCin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ZisanCin.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jodit@3.24.5/build/jodit.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jodit@4/build/jodit.min.css" />

    <link rel="stylesheet" href="https://cdn.datatables.net/2.3.2/css/dataTables.dataTables.css" />


    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>
<body>

    <style>
        :root {
            --nav-bg: rgba(255, 255, 255, 0.9);
            --nav-border: rgba(231, 234, 243, 0.7);
            --primary-gradient: linear-gradient(135deg, #4361ee 0%, #3a0ca3 100%);
        }

        /* Navbar Ana Gövde */
        .admin-navbar {
            background: var(--nav-bg) !important;
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--nav-border);
            padding: 0.8rem 1.5rem;
            position: sticky;
            top: 0;
            z-index: 1050;
        }

        /* Logo ve Marka */
        .navbar-brand {
            font-size: 1.1rem;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        /* Navigasyon Linkleri */
        .admin-navbar .nav-link {
            color: #677788 !important;
            font-weight: 500;
            font-size: 0.9rem;
            padding: 0.6rem 1rem !important;
            border-radius: 10px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .admin-navbar .nav-link i {
                font-size: 1.1rem;
                transition: transform 0.3s ease;
            }

            /* Hover ve Active Durumları */
            .admin-navbar .nav-link:hover {
                color: #4361ee !important;
                background: rgba(67, 97, 238, 0.05);
            }

                .admin-navbar .nav-link:hover i {
                    transform: translateY(-2px);
                }

        .admin-navbar .nav-item.active .nav-link {
            color: #4361ee !important;
            background: rgba(67, 97, 238, 0.1);
        }

        /* Ayırıcı Çizgi (Mobil için gizli) */
        .nav-divider {
            width: 1px;
            height: 20px;
            background: #e7eaf3;
            margin: 0 10px;
            align-self: center;
        }

        /* Çıkış Butonu Özel */
        .nav-logout {
            color: #ed4c78 !important;
            border: 1px solid transparent;
        }

            .nav-logout:hover {
                background: rgba(237, 76, 120, 0.1) !important;
                border-color: rgba(237, 76, 120, 0.2) !important;
            }

        /* Mobil Düzenlemeler */
        @@media (max-width: 991.98px) {
            .nav-divider {
                display: none;
            }

            .admin-navbar {
                background: #fff !important;
            }

            .navbar-collapse {
                padding-top: 1rem;
                margin-top: 0.5rem;
                border-top: 1px solid #eee;
            }
        }
    </style>
    <header>
        <nav class="navbar navbar-expand-lg admin-navbar shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="Admin" asp-controller="Main" asp-action="Index">
                    <i class="bi bi-cpu-fill me-1"></i> Özlem Gürbüz Nazlı <span class="text-dark opacity-50 fw-light">| Admin</span>
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Main" asp-action="Index">
                                <i class="bi bi-grid-1x2-fill"></i> Panel
                            </a>
                        </li>

                        <div class="nav-divider"></div>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Blogs" asp-action="Index">
                                <i class="bi bi-journal-bookmark-fill"></i> Bloglar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Services" asp-action="Index">
                                <i class="bi bi-briefcase-fill"></i> Hizmetler
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Sliders" asp-action="Index">
                                <i class="bi bi-images"></i> Slider
                            </a>
                        </li>

                        <div class="nav-divider"></div>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Abouts" asp-action="Index">
                                <i class="bi bi-info-circle-fill"></i> Hakkımızda
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Faqs" asp-action="Index">
                                <i class="bi bi-patch-question-fill"></i> SSS
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="ContactForms" asp-action="Index">
                                <i class="bi bi-envelope-paper-fill"></i> Mesajlar
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Users" asp-action="Index" title="Kullanıcılar">
                                <i class="bi bi-people-fill"></i>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="SiteSettings" asp-action="Index" title="Site Ayarları">
                                <i class="bi bi-gear-fill"></i>
                            </a>
                        </li>
                        <div class="nav-divider"></div>
                        <li class="nav-item">
                            <a class="nav-link nav-logout fw-bold" asp-area="Admin" asp-controller="Login" asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> Güvenli Çıkış
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    

    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/jodit@3.24.5/build/jodit.min.js"></script>
    <script src="https://cdn.datatables.net/2.3.2/js/dataTables.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
