@model IEnumerable<Faq>

@{
    ViewData["Title"] = "SSS Yönetimi";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.9);
    }

    body {
        background-color: #f0f2f5;
        font-family: 'Inter', sans-serif;
    }

    .admin-card {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 16px;
    }

    .table thead th {
        background-color: transparent;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.05rem;
        font-weight: 700;
        color: #6c757d;
        border-bottom: 1px solid #eee;
        padding: 15px;
    }

    /* Soru ve Cevap Önizleme */
    .question-text {
        font-weight: 600;
        color: #2b2d42;
        font-size: 0.95rem;
    }

    .answer-preview {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #6c757d;
        font-size: 0.85rem;
        line-height: 1.5;
    }

    /* İşlem Butonları */
    .btn-action {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.2s;
        border: none;
    }

    .btn-view {
        background: rgba(13, 202, 240, 0.1);
        color: #0dcaf0;
    }

    .btn-edit {
        background: rgba(67, 97, 238, 0.1);
        color: #4361ee;
    }

    .btn-delete {
        background: rgba(230, 57, 70, 0.1);
        color: #e63946;
    }

    .btn-action:hover {
        transform: translateY(-2px);
        filter: brightness(0.9);
        color: #fff;
    }

    .btn-view:hover {
        background: #0dcaf0;
    }

    .btn-edit:hover {
        background: #4361ee;
    }

    .btn-delete:hover {
        background: #e63946;
    }

    /* Arama Çubuğu */
    .search-wrapper {
        position: relative;
    }

        .search-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
        }

        .search-wrapper .form-control {
            padding-left: 40px;
            border-radius: 12px;
            border: 1px solid #e0e0e0;
        }
</style>

<div class="container-fluid py-5 px-4">
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h1 class="h3 fw-bold text-dark mb-1">Sıkça Sorulan Sorular</h1>
            <p class="text-muted mb-0">Müşterilerinizin en çok merak ettiği soruları buradan düzenleyin.</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-plus-lg me-2"></i> Yeni SSS Ekle
            </a>
        </div>
    </div>

    <div class="card admin-card shadow-lg border-0">
        <div class="p-4 bg-white rounded-top-4 border-bottom d-flex justify-content-between align-items-center">
            <div class="search-wrapper w-25">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" class="form-control" placeholder="Sorularda ara...">
            </div>
            <span class="badge bg-light text-dark fw-normal border">Toplam @Model.Count() Kayıt</span>
        </div>

        <div class="table-responsive p-0">
            <table class="table align-middle table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Soru</th>
                        <th>Cevap Özeti</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="blogTable">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="question-text">@item.Question</div>
                            </td>
                            <td>
                                <div class="answer-preview">
                                    @Html.Raw(item.Answer)
                                </div>
                                <div class="full-answer-content d-none">
                                    @Html.Raw(item.Answer)
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <button type="button" class="btn-action btn-view view-btn" data-bs-toggle="modal" data-bs-target="#answerModal" title="Görüntüle">
                                        <i class="bi bi-eye-fill"></i>
                                    </button>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit" title="Düzenle">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete" title="Sil">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="answerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-bottom-0 p-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-chat-left-text text-primary me-2"></i> Cevap Detayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Kapat"></button>
            </div>
            <div class="modal-body p-4 pt-0" id="modalAnswerBody" style="font-size: 1.05rem; line-height: 1.6; color: #4a4e69;">
            </div>
            <div class="modal-footer border-top-0 p-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Arama
        document.getElementById("searchInput").addEventListener("keyup", function () {
            var value = this.value.toLowerCase();
            var rows = document.querySelectorAll("#blogTable tr");
            rows.forEach(function (row) {
                row.style.display = row.textContent.toLowerCase().includes(value) ? "" : "none";
            });
        });

        // Modal Doldurma
        document.querySelectorAll('.view-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var row = this.closest('tr');
                var fullContent = row.querySelector('.full-answer-content').innerHTML;
                document.getElementById('modalAnswerBody').innerHTML = fullContent;
            });
        });
    </script>
}