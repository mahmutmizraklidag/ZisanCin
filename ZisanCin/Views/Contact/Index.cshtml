					</div>
				</div>
			</div>
		</div>
	</section>

	<div class="bg-light2 2xxl:py-25 xl:17.5 md:py-12.5 sm:py-10 py-7.5">
		<div class="container">
			<div class="sm:p-2.5 p-1.25 bg-white/50 lg:h-120 sm:h-100 h-75 rounded-2xl overflow-hidden wow fadeInUp" data-wow-delay="0.4s" data-wow-duration="0.8s">
				<iframe class="size-full rounded-2xl" src="@DataRequestModel.SiteSetting.mapLink" width="600" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
			</div>
		</div>
