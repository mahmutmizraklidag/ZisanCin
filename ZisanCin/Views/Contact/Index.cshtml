							<a asp-controller="Service" asp-action="Index" class="font-medium mt-7.5 block text-primary [.box-hover.active_&]:text-white">Detaylar <i class="feather icon-arrow-right-circle"></i></a>
						</div>
					</div>
				</div>

				<div class="xl:w-1/3 md:w-1/2 w-full mb-7.5 wow fadeInUp" data-wow-delay="0.4s" data-wow-duration="0.8s">
					<div class="relative lg:p-7.5 lg:pr-30 lg:pb-6.25 p-6.25 pr-26.25 pb-5 z-1 drop-shadow-[0_10px_30px_rgba(var(--primary-rgb),0.1)] min-h-50 h-full overflow-hidden before:content-['02'] before:text-8xl before:leading-[1.2] before:font-semibold before:text-secondary before:opacity-10 before:absolute before:right-6.25 before:top-5 before:z-2 before:duration-500 after:bg-white after:absolute after:size-full after:top-0 after:left-0 after:-z-1 after:mask-[url(../images/bg01.svg)] after:mask-position-[right_bottom] after:rounded-2xl after:rounded-ee-0 after:duration-500 box-hover [.box-hover.active]:before:text-white [.box-hover.active]:after:bg-primary active">
						<div class="mask-[url(../images/bg01.svg)] mask-position-[right_bottom] absolute left-0 top-0 size-full rounded-2xl opacity-0 bg-primary bg-blend-color-burn bg-center bg-cover z-0 [.box-hover.active_&]:opacity-100"></div>
						<div class="size-22.5 absolute right-0 bottom-0 rounded-2xl bg-white flex items-center justify-center [.box-hover.active_&]:bg-primary">
							<span class="icon-cell">
								<i class="flaticon-drugs flex text-6xl text-primary [.box-hover.active_&]:text-white"></i>
							</span>
						</div>
						<div class="relative z-1">
							<h3 class="lg:text-2xl lg:mb-5 lg:pb-5 text-lg mb-3 pb-3 font-semibold relative after:w-full after:h-px after:absolute after:opacity-30 after:left-0 after:bottom-0 after:bg-linear-(--title2-gradient) [.box-hover.active_&]:after:bg-linear-(--title3-gradient) [.box-hover.active_&]:text-white">Sosyal Hayatla Uyum</h3>
							<p class="[.box-hover.active_&]:text-white">Diyet sürecinde sosyal hayatınızdan kopmadan, dışarıdaki öğünlerinizi yönetmeyi öğretiyoruz.</p>
							<a asp-controller="Service" asp-action="Index" class="font-medium mt-7.5 block text-primary [.box-hover.active_&]:text-white">Detaylar <i class="feather icon-arrow-right-circle"></i></a>
						</div>
					</div>
				</div>

				<div class="xl:w-1/3 md:w-1/2 w-full mb-7.5 wow fadeInUp" data-wow-delay="0.6s" data-wow-duration="0.8s">
					<div class="relative lg:p-7.5 lg:pr-30 lg:pb-6.25 p-6.25 pr-26.25 pb-5 z-1 drop-shadow-[0_10px_30px_rgba(var(--primary-rgb),0.1)] min-h-50 h-full overflow-hidden before:content-['03'] before:text-8xl before:leading-[1.2] before:font-semibold before:text-secondary before:opacity-10 before:absolute before:right-6.25 before:top-5 before:z-2 before:duration-500 after:bg-white after:absolute after:size-full after:top-0 after:left-0 after:-z-1 after:mask-[url(../images/bg01.svg)] after:mask-position-[right_bottom] after:rounded-2xl after:rounded-ee-0 after:duration-500 box-hover [.box-hover.active]:before:text-white [.box-hover.active]:after:bg-primary">
						<div class="mask-[url(../images/bg01.svg)] mask-position-[right_bottom] absolute left-0 top-0 size-full rounded-2xl opacity-0 bg-primary bg-blend-color-burn bg-center bg-cover z-0 [.box-hover.active_&]:opacity-100"></div>
						<div class="size-22.5 absolute right-0 bottom-0 rounded-2xl bg-white flex items-center justify-center [.box-hover.active_&]:bg-primary">
							<span class="icon-cell">
								<i class="flaticon-doctor flex text-6xl text-primary [.box-hover.active_&]:text-white"></i>
							</span>
						</div>
