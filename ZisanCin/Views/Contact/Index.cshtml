						<div class="size-22.5 absolute right-0 bottom-0 rounded-2xl bg-white flex items-center justify-center [.box-hover.active_&]:bg-primary">
							<span class="icon-cell">
								<i class="flaticon-medical-symbol flex text-6xl text-primary [.box-hover.active_&]:text-white"></i>
							</span>
						</div>
						<div class="relative z-1">
							<h3 class="lg:text-2xl lg:mb-5 lg:pb-5 text-lg mb-3 pb-3 font-semibold relative after:w-full after:h-px after:absolute after:opacity-30 after:left-0 after:bottom-0 after:bg-linear-(--title2-gradient) [.box-hover.active_&]:after:bg-linear-(--title3-gradient) [.box-hover.active_&]:text-white">Sürdürülebilir Beslenme</h3>
