                <div class="row box-hover-wrapper">
                    @foreach (var item in Model.Services)
                    {
                        <div class="xl:w-1/3 md:w-1/2 w-full mb-7.5 wow fadeInUp">
                            <div class="rounded-xxl h-full relative flex flex-col bg-white duration-700 box-hover [.box-hover.active]:bg-primary">
                                <div class="relative overflow-hidden rounded-t-xxl">
                                    <img src="img/@item.Image"
                                         alt="@item.Title"
                                         style="width:100%; height:315px; object-fit:cover; object-position:center -90px; display:block;" />
                                </div>
                                <div class="p-7.5 flex-1 flex-col flex">
                                    <h3 class="text-xl mb-2.5 duration-700 [.box-hover.active_&]:text-white">@item.Title</h3>
                                    <p class="mb-6.25 duration-700 [.box-hover.active_&]:text-white">
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            // HTML etiketlerini temizle (Regex ile)
                                            var plainText = System.Text.RegularExpressions.Regex.Replace(item.Description, "<.*?>", String.Empty);
        
                                            // İlk 100 karakteri al ve ... ekle
                                            var shortText = plainText.Length > 100 ? plainText.Substring(0, 100) + "..." : plainText;
        
                                            @Html.Raw(shortText)
                                        }
                                    </p>
                                    <a asp-controller="Service" asp-action="Detail" asp-route-slug="@item.Slug" class="mt-auto font-medium text-primary duration-700 [.box-hover.active_&]:text-white">Daha Fazla... <i class="feather icon-arrow-right-circle inline-block text-base"></i></a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

  
  

@*VKİ*@
<section class="bg-light content-wrapper style-35">
    <div class="row gx-0">
        <div class="lg:w-7/12 w-full">
            <div class="relative h-full">
                    <img src="images/background/vki.png" alt="" class="h-full">
               
            </div>
        </div>

        <div class="lg:w-5/12 w-full">
            <div class="bg-secondary h-full xl:py-31.25 xl:px-20 sm:py-21.25 sm:px-12.5 py-12.5 px-7.5 wow fadeInUp"
                 data-wow-delay="0.4s"
                 style="visibility: visible; animation-delay: 0.4s; animation-name: fadeInUp;">
                <div class="w-full">
                        <div class="mb-10 max-w-[760px] w-full">
                            <h2 class="2xxl:text-5xl lg:text-[42px] sm:text-[34px] text-2xxl font-bold leading-[1.2] mb-0 text-white">
                                Beden Kütle İndeksini
                                <span class="block">Hesapla</span>
                            </h2>
                        </div>

                    <div class="custom-tab">
                        <ul class="flex flex-wrap gap-3 mb-5" id="myTab1" role="tablist">
                            <li class="tab-title active" role="presentation">
                                <button type="button" class="text-2xs font-semibold py-1.75 px-3.75 rounded-[7px] uppercase bg-[#32382A] text-white/50 [.tab-title.active_&]:text-black [.tab-title.active_&]:bg-primary-second duration-500 active">
                                    Metrik
                                </button>
                            </li>
                        </ul>
                            <style>
                                #bmiForm .row {
                                    display: flex;
                                    flex-wrap: wrap;
                                }

                                #bmiForm .col-md-6 {
                                    width: 50%;
                                }

                                #bmiForm .col-12 {
                                    width: 100%;
                                }

                                @@media (max-width: 767px) {
                                    #bmiForm .col-md-6 {
                                        width: 100%;
                                    }
                                }

                                #bmiForm .bmi-select option {
                                    color: #000 !important;
                                    background-color: #fff !important;
                                }
                            </style>
                        <div class="tab-content-area" id="myTabContent">
                            <div class="tab-content active">
                                    <form id="bmiForm" class="bmi-form">
                                        @Html.AntiForgeryToken()

                                        <div class="row g-4">
                                            <div class="col-12">
                                                <div class="relative">
                                                    <label asp-for="BodyMass.Name" class="block mb-2 text-base text-white font-medium"></label>
                                                    <input asp-for="BodyMass.Name"
                                                           placeholder="Ad Soyad"
                                                           class="h-15 py-3.75 px-6.25 rounded-2xl border border-white/50 bg-white/[0.08] text-white text-2sm block w-full" />
                                                    <span asp-validation-for="BodyMass.Name" class="text-danger text-sm"></span>
                                                </div>
                                            </div>

                                            <div class="col-12">
                                                <div class="relative">
                                                    <label asp-for="BodyMass.Phone" class="block mb-2 text-base text-white font-medium"></label>
                                                    <input asp-for="BodyMass.Phone"
                                                           placeholder="Telefon"
                                                           class="h-15 py-3.75 px-6.25 rounded-2xl border border-white/50 bg-white/[0.08] text-white text-2sm block w-full" />
                                                    <span asp-validation-for="BodyMass.Phone" class="text-danger text-sm"></span>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="relative">
                                                    <label asp-for="BodyMass.Age" class="block mb-2 text-base text-white font-medium"></label>
                                                    <input asp-for="BodyMass.Age" type="number" min="1" max="120"
                                                           placeholder="Yaş"
                                                           class="h-15 py-3.75 px-6.25 rounded-2xl border border-white/50 bg-white/[0.08] text-white text-2sm block w-full" />
                                                    <span asp-validation-for="BodyMass.Age" class="text-danger text-sm"></span>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="relative">
                                                    <label asp-for="BodyMass.Gender" class="block mb-2 text-base text-white font-medium"></label>
                                                    <select asp-for="BodyMass.Gender"
                                                            class="h-15 py-3.75 px-6.25 rounded-2xl border border-white/50 bg-white/[0.08] text-white text-2sm block w-full bmi-select">
                                                        <option value="">Cinsiyet Seçiniz</option>
                                                        <option value="Erkek">Erkek</option>
                                                        <option value="Kadın">Kadın</option>
                                                    </select>
                                                    <span asp-validation-for="BodyMass.Gender" class="text-danger text-sm"></span>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="relative">
                                                    <label asp-for="BodyMass.Height" class="block mb-2 text-base text-white font-medium"></label>
                                                    <input asp-for="BodyMass.Height" type="number" step="0.1" min="50" max="250"
                                                           placeholder="CM"
                                                           class="h-15 py-3.75 px-6.25 rounded-2xl border border-white/50 bg-white/[0.08] text-white text-2sm block w-full" />
                                                    <span asp-validation-for="BodyMass.Height" class="text-danger text-sm"></span>
                                                </div>
                                            </div>

                                            <div class="col-md-6">
                                                <div class="relative">
                                                    <label asp-for="BodyMass.Weight" class="block mb-2 text-base text-white font-medium"></label>
                                                    <input asp-for="BodyMass.Weight" type="number" step="0.1" min="10" max="500"
                                                           placeholder="KG"
                                                           class="h-15 py-3.75 px-6.25 rounded-2xl border border-white/50 bg-white/[0.08] text-white text-2sm block w-full" />
                                                    <span asp-validation-for="BodyMass.Weight" class="text-danger text-sm"></span>
                                                </div>
                                            </div>

                                            <div class="col-12">
                                                <button id="bmiSubmitBtn" name="submit" type="submit" value="Submit"
                                                        class="btn btn-lg btn-icon btn-primary">
                                                    Hesapla
                                                    <span class="size-11 min-w-11 bg-white rounded-2lg text-heading inline-flex items-center justify-center -my-2.75 -mr-4.5 ml-3">
                                                        <i class="feather icon-arrow-right group-hover:animate-toRightFromLeft"></i>
                                                    </span>
                                                </button>
                                            </div>
                                        </div>
                                    </form>

                                <div id="bmiResultBox" class="mt-6 hidden">
                                    <div class="p-4 rounded-2xl border border-white/30 bg-white/[0.08] text-white">
                                        <p class="mb-2 text-white"><strong>VKI:</strong> <span id="bmiValue"></span></p>
                                            <p class="mb-0 text-white"><strong>Durum:</strong> <span id="bmiStatus"></span></p>
                                    </div>
                                </div>

                                <div id="bmiErrorBox" class="mt-4 hidden">
                                    <div class="p-4 rounded-2xl border border-red-400/30 bg-red-500/10 text-white">
                                        <span id="bmiErrorText"></span>
                                    </div>
                                </div>

                                <div id="bmiSuccessBox" class="mt-4 hidden">
                                    <div class="p-4 rounded-2xl border border-green-400/30 bg-green-500/10 text-white">
                                        <span id="bmiSuccessText"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

        <script>
                document.getElementById("bmiForm").addEventListener("submit", async function (e) {
                    e.preventDefault();

                    const form = this;
                    const submitBtn = document.getElementById("bmiSubmitBtn");
                    const resultBox = document.getElementById("bmiResultBox");
                    const errorBox = document.getElementById("bmiErrorBox");
                    const successBox = document.getElementById("bmiSuccessBox");
                    const errorText = document.getElementById("bmiErrorText");
                    const successText = document.getElementById("bmiSuccessText");

                    document.querySelectorAll("[data-valmsg-for]").forEach(x => x.textContent = "");
                    errorBox.classList.add("hidden");
                    successBox.classList.add("hidden");

                    submitBtn.disabled = true;

                    try {
                        const formData = new FormData(form);

                        const response = await fetch('@Url.Action("CalculateBmiAjax", "Home")', {
                            method: "POST",
                            body: formData,
                            headers: {
                                "RequestVerificationToken": formData.get("__RequestVerificationToken")
                            }
                        });

                        const data = await response.json();

                        if (!data.success) {
                            resultBox.classList.add("hidden");

                            if (data.errors) {
                                for (const key in data.errors) {
                                    const span = document.querySelector(`[data-valmsg-for='${key}']`);
                                    if (span) {
                                        span.textContent = data.errors[key];
                                    }
                                }
                            }

                            if (data.message) {
                                errorText.textContent = data.message;
                                errorBox.classList.remove("hidden");
                            }

                            return;
                        }

                        document.getElementById("bmiValue").textContent = data.bmi;
                        document.getElementById("bmiStatus").textContent = data.status;
                        resultBox.classList.remove("hidden");

                        successText.textContent = data.message;
                        successBox.classList.remove("hidden");

                        form.reset();
                    } catch (err) {
                        resultBox.classList.add("hidden");
                        errorText.textContent = "İşlem sırasında bir hata oluştu.";
                        errorBox.classList.remove("hidden");
                    } finally {
                        submitBtn.disabled = false;
                    }
                });
        </script>
}

