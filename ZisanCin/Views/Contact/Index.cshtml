@{
	ViewData["Title"] = "İletişim";
	ViewData["MetaDescription"] = "Diyetisyen Zişan CİN iletişim";
	ViewData["MetaKeywords"] = "Diyetisyen Zişan CİN iletişim";
	var reCaptchaSiteKey = ViewBag.ReCaptchaSiteKey as string;
}
<style>
	.bg-light2{
		background-color: #F4F8E9 !important;
	}

	.bg-light {
		background-color: #fff !important;
	}
</style>
<main class="page-content">

	<!-- Banner  -->
	<div class="lg:min-h-125 md:min-h-100 sm:min-h-87.5 min-h-75 bg-cover bg-center bg-light2 relative z-1 w-full overflow-hidden flex" style="background-image:url(images/banner/bnr1.webp);">
		<div class="container relative z-1 h-auto table">
			<div class="row">
				<div class="lg:w-2/3">
					<div class="table-cell lg:h-125 md:h-100 sm:h-87.5 h-75 align-middle pt-17.5 pb-5 xl:ps-17.5 max-md:text-center">
						<h1 class="2xxl:text-7xl xl:text-6xxl md:text-[48px] text-4xl font-bold mb-1.25 leading-[1.2] break-word !text-white wow fadeInUp" data-wow-delay="0.2s" data-wow-duration="0.8s">İletişim</h1>
						<nav class="wow fadeInUp" data-wow-delay="0.4s" data-wow-duration="0.8s">
							<ul class="inline-block rounded-5xl lg:py-2.5 py-1.5 lg:px-7.5 px-5 bg-white shadow-breadcrumb">
								<li class="inline-block lg:text-base text-sm font-normal capitalize text-primary"><a asp-controller="Home" asp-action="Index">Anasayfa</a></li>
								<li class="inline-block lg:text-base text-sm font-normal capitalize text-primary pl-2 relative before:content-['\f101'] before:float-left before:text-primary before:font-bold before:font-['Font_Awesome_5_Free'] before:text-sm before:pr-3 before:top-0.5 before:relative">İletişim</li>
							</ul>
						</nav>
					</div>
				</div>
			</div>
			<div class="absolute right-[-2%] bottom-[-2%] float-right max-3xl:w-130 max-lg:hidden">
				<img src="images/banner/background.png" alt="" class="wow fadeInUp" data-wow-delay="0.2s" data-wow-duration="0.8s">
			</div>
		</div>
		<div class="absolute z-9 bottom-[5%] right-[45%] max-xl:hidden"><img class="animate-move1" src="images/banner/item1.png" alt=""></div>
		<div class="absolute z-9 3xl:top-[30%] top-2/5 right-[35%] max-xl:hidden"><img class="animate-move2" src="images/banner/item2.png" alt=""></div>
		<div class="absolute z-9 3xl:bottom-[20%] right-[10%] bottom-[30%] max-xl:hidden"><img class="animate-move3" src="images/banner/item3.png" alt=""></div>
		<div class="absolute z-9 bottom-[20%] 3xl:right-[18%] right-[5%] max-xl:hidden"><img class="animate-move3" src="images/banner/item4.png" alt=""></div>
		<div class="h-full w-25 min-w-25 absolute bottom-0 flex justify-between items-center flex-col py-6.25 px-3.75 left-0 border-r border-white/10 z-1 max-xl:hidden">
			<ul class="flex gap-7.5 [writing-mode:sideways-lr]">
				<li><a class="text-xs font-semibold uppercase text-white tracking-[1px]" href="@DataRequestModel.SiteSetting.Facebook" target="_blank">Facebook</a></li>
				<li><a class="text-xs font-semibold uppercase text-white tracking-[1px]" href="@DataRequestModel.SiteSetting.YouTube" target="_blank">Youtube</a></li>
				<li><a class="text-xs font-semibold uppercase text-white tracking-[1px]" href="@DataRequestModel.SiteSetting.Instagram" target="_blank">Instagram</a></li>
			</ul>
			<a asp-controller="Contact" asp-action="" class="btn btn-white btn-sm !py-2 !px-4 shadow-btn [writing-mode:sideways-lr] !rounded-2xl">Hadi Başlayalım</a>
		</div>
	</div>
	<!-- Banner End -->

	<section class="2xxl:py-25 xl:17.5 md:py-12.5 sm:py-10 py-7.5">
		<div class="container">
			<div class="row">
				<div class="xl:w-2/3 order-2 xl:order-1">
					<div class="wow fadeInUp" data-wow-delay="1.0s" data-wow-duration="0.8s">
						<div class="form-body bg-white">
							<form action="#" id="iletisimFormu" method="post">
								<div class="dzFormMsg !p-0"></div>
								<div class="flex flex-wrap">

									<div class="sm:w-1/2 w-full px-2">
										<div class="relative flex flex-wrap items-stretch w-full mb-7">
											<input name="Name" type="text" class="py-2.5 px-5 bg-light2 w-full outline-none text-black rounded-2lg h-15" id="Name" placeholder="Ad Soyad">
										</div>
									</div>

									<div class="sm:w-1/2 w-full px-2">
										<div class="relative flex flex-wrap items-stretch w-full mb-7">
											<input name="Phone"
												   type="tel"
												   class="py-2.5 px-5 bg-light2 w-full outline-none text-black rounded-2lg h-15"
												   id="Phone"
												   placeholder="Telefon"
												   maxlength="11"
												   pattern="[0-9]*"
												   inputmode="numeric"
												   oninput="if (this.value.length > 11) this.value = this.value.slice(0, 11);">
										</div>
									</div>

								</div>

								<div class="w-full">
									<div class="relative flex flex-wrap items-stretch w-full mb-7">
										<input name="Email" type="email" class="py-2.5 px-5 bg-light2 w-full outline-none text-black rounded-2lg h-15" id="Email" placeholder="Email">
									</div>
								</div>
								<div class="w-full">
									<div class="relative flex flex-wrap items-stretch w-full mb-7">
										<input name="Subject" type="text" class="py-2.5 px-5 bg-light2 w-full outline-none text-black rounded-2lg h-15" id="Subject" placeholder="Konu">
									</div>
								</div>
								<div class="w-full">
									<div class="relative flex flex-wrap items-stretch w-full mb-7">
										<textarea name="Message" class="py-2.5 px-5 bg-light2 w-full outline-none text-black rounded-2lg min-h-68.75 h-full" id="Message" rows="10" placeholder="Mesajınız..."></textarea>
									</div>
								</div>
								@if (!string.IsNullOrWhiteSpace(reCaptchaSiteKey))
								{
									<div class="col-lg-12 mb-3">
										<div class="g-recaptcha" data-sitekey="@reCaptchaSiteKey"></div>
									</div>
								}
								<div class="w-full">
									<button type="submit" name="submit" value="submit" class="btn btn-lg btn-icon btn-primary btn-shadow">
										Görder <span class="size-11 min-w-11 bg-white rounded-2lg text-heading inline-flex items-center justify-center -my-2.75 -mr-4.5 ml-3"><i class="feather icon-arrow-right group-hover:animate-toRightFromLeft"></i></span>
									</button>
								</div>
								<!-- Mesaj kutuları -->
								<div class="alert alert-success sent-message mt-3 text-center" style="display:none;">Mesajınız gönderildi.</div>
								<div class="alert alert-danger error-message mt-3 text-center" style="display:none;"></div>
							</form>
						</div>
					</div>
				</div>
				<div class="xl:w-1/3 mb-7.5 order-1 xl:order-2">
					<div class="md:py-10.5 md:px-7.5 py-7.5 px-6.25 rounded-2xl bg-light">

						<div class="flex gap-3.75 text-left relative items-center mb-5 wow fadeInUp" data-wow-delay="0.4s" data-wow-duration="0.8s" style="visibility: visible; animation-duration: 0.8s; animation-delay: 0.4s; animation-name: fadeInUp;">
							<div class="lg:size-15 lg:min-w-15 size-12.5 min-w-12.5 bg-primary text-white lg:text-2xl text-lg rounded-full flex items-center justify-center">
								<span class="icon-cell">
									<i class="feather icon-map-pin flex"></i>
								</span>
							</div>
							<div class="overflow-hidden">
								<h5 class="text-lg mb-0 font-semibold">Adres</h5>
								<p class="text-base font-light mb-0">
                                    @DataRequestModel.SiteSetting.Address
								</p>
							</div>
						</div>
						<div class="flex gap-3.75 text-left relative items-center mb-5 wow fadeInUp" data-wow-delay="0.6s" data-wow-duration="0.8s" style="visibility: visible; animation-duration: 0.8s; animation-delay: 0.6s; animation-name: fadeInUp;">
							<div class="lg:size-15 lg:min-w-15 size-12.5 min-w-12.5 bg-primary text-white lg:text-2xl text-lg rounded-full flex items-center justify-center">
								<span class="icon-cell">
									<i class="feather icon-phone flex"></i>
								</span>
							</div>
							<div class="overflow-hidden">
								<h5 class="text-lg mb-0 font-semibold">Telefon</h5>
								<p class="text-base font-light mb-0"><a href="tel:@DataRequestModel.SiteSetting.Phone">@DataRequestModel.SiteSetting.Phone</a></p>
							</div>
						</div>
						<div class="flex gap-3.75 text-left relative items-center mb-5 wow fadeInUp" data-wow-delay="0.8s" data-wow-duration="0.8s" style="visibility: visible; animation-duration: 0.8s; animation-delay: 0.8s; animation-name: fadeInUp;">
							<div class="lg:size-15 lg:min-w-15 size-12.5 min-w-12.5 bg-primary text-white lg:text-2xl text-lg rounded-full flex items-center justify-center">
								<span class="icon-cell">
									<i class="feather icon-mail flex"></i>
								</span>
							</div>
							<div class="overflow-hidden">
								<h5 class="text-lg mb-0 font-semibold">E-Mail</h5>
								<p class="text-base font-light mb-0">
									<a href="mailto:@DataRequestModel.SiteSetting.Email">
										@DataRequestModel.SiteSetting.Email
									</a>
								</p>
							</div>
						</div>
						<div class="flex gap-3.75 text-left relative items-center wow fadeInUp" data-wow-delay="1.0s" data-wow-duration="0.8s" style="visibility: visible; animation-duration: 0.8s; animation-delay: 1s; animation-name: fadeInUp;">
							<div class="lg:size-15 lg:min-w-15 size-12.5 min-w-12.5 bg-primary text-white lg:text-2xl text-lg rounded-full flex items-center justify-center">
								<span class="icon-cell">
									<i class="feather icon-clock flex"></i>
								</span>
							</div>
							<div class="overflow-hidden">
								<h5 class="text-lg mb-0 font-semibold">Çalışma Saatleri</h5>
								<p class="text-base font-light mb-0">Pzt-Cum: 9:30 - 19:00 <br> Cts: 9:30 - 18:00</p>
							</div>
						</div>

					</div>
				</div>
			</div>
		</div>
	</section>

