@model About

@{
    ViewData["Title"] = "Yeni İçerik Ekle";
}

<style>
    .form-card {
        background: #fff;
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .nav-pills .nav-link {
        color: #6c757d;
        font-weight: 500;
        padding: 12px 20px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .nav-pills .nav-link.active {
            background-color: #28a745; /* Create için daha pozitif bir renk (Yeşil tonu) */
            color: #fff;
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        }

    .form-control {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #28a745;
            box-shadow: 0 0 0 0.25rem rgba(40, 167, 69, 0.1);
        }

    .upload-zone {
        border: 2px dashed #dee2e6;
        border-radius: 15px;
        padding: 20px;
        text-align: center;
        transition: 0.3s;
        cursor: pointer;
        background: #fdfdfd;
    }

        .upload-zone:hover {
            border-color: #28a745;
            background: #f1fcf4;
        }

    .section-header {
        border-left: 5px solid #28a745;
        padding-left: 15px;
        margin-bottom: 25px;
    }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Yeni İçerik Tanımla</h2>
            <p class="text-muted small">Björn Coffee & Kurumsal projeleriniz için yeni bir 'Hakkımızda' bölümü oluşturun.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
            <i class="bi bi-list-ul me-1"></i> Listeye Dön
        </a>
    </div>

    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 d-none"></div>

        <ul class="nav nav-pills mb-4 gap-2" id="createTab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active shadow-sm" data-bs-toggle="pill" data-bs-target="#content-data" type="button">
                    <i class="bi bi-pencil-square me-2"></i> İçerik Bilgileri
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link shadow-sm" data-bs-toggle="pill" data-bs-target="#home-data" type="button">
                    <i class="bi bi-layout-sidebar me-2"></i> Vitrin Ayarları
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link shadow-sm" data-bs-toggle="pill" data-bs-target="#seo-data" type="button">
                    <i class="bi bi-google me-2"></i> SEO & Meta
                </button>
            </li>
        </ul>

        <div class="tab-content border-0">
            <div class="tab-pane fade show active" id="content-data">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Detaylı Bilgiler</h5>
                        <small class="text-muted">Sayfanın ana gövdesinde görünecek alanlar.</small>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label fw-bold">Sayfa Başlığı</label>
                            <input asp-for="Title" class="form-control" placeholder="Örn: Biz Kimiz? veya Vizyonumuz" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Hakkımızda Metni</label>
                            <textarea id="AboutEditor" asp-for="Description" class="form-control"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Ana Görsel</label>
                            <div class="upload-zone" onclick="document.getElementById('imageInput').click()">
                                <i class="bi bi-cloud-arrow-up fs-2 text-muted"></i>
                                <p class="mb-0 text-muted">Görsel seçmek için tıklayın veya sürükleyin</p>
                                <input asp-for="Image" type="file" id="imageInput" class="d-none" />
                            </div>
                            <div class="mt-3 text-center">
                                <img id="previewImage" src="#" alt="Önizleme" class="rounded shadow-sm d-none" style="max-height: 200px; border: 3px solid #fff;" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="home-data">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Ana Sayfa Kart Ayarları</h5>
                        <small class="text-muted">Ana sayfadaki kısa özet alanı için ayarlar.</small>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="HomeTitle" class="form-label fw-bold">Özet Başlık</label>
                            <input asp-for="HomeTitle" class="form-control" placeholder="Ana sayfada görünecek başlık" />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="HomeDescription" class="form-label fw-bold">Kısa Özet</label>
                            <textarea asp-for="HomeDescription" class="form-control" rows="3" placeholder="Maksimum 200 karakter önerilir..."></textarea>
                        </div>
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Özet Görseli</label>
                            <input asp-for="HomeImage" type="file" id="imageInput2" class="form-control" />
                            <div class="mt-3 text-center">
                                <img id="previewImage2" src="#" class="rounded shadow-sm d-none" style="max-height: 150px;" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="seo-data">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Arama Motoru Ayarları</h5>
                        <small class="text-muted">İçeriğin Google sonuçlarında nasıl görüneceğini belirleyin.</small>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="MetaTitle" class="form-label fw-bold">SEO Başlığı</label>
                            <input asp-for="MetaTitle" class="form-control" placeholder="Google başlığı..." />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Keywords" class="form-label fw-bold">Anahtar Kelimeler</label>
                            <input asp-for="Keywords" class="form-control" placeholder="kahve, eğitim, danışmanlık..." />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="MetaDescription" class="form-label fw-bold">SEO Açıklaması</label>
                            <textarea asp-for="MetaDescription" class="form-control" rows="2" placeholder="Arama sonuçlarında görünecek kısa açıklama"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 mb-5 d-flex justify-content-end align-items-center gap-3">
            <span class="text-muted small d-none d-md-inline">* Tüm zorunlu alanları doldurduğunuzdan emin olun.</span>
            <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 shadow">
                <i class="bi bi-cloud-check me-2"></i> İçeriği Yayınla
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Önizleme fonksiyonu
        function handlePreview(inputId, previewId) {
            document.getElementById(inputId).addEventListener("change", function (e) {
                const [file] = e.target.files;
                const preview = document.getElementById(previewId);
                if (file) {
                    preview.src = URL.createObjectURL(file);
                    preview.classList.remove("d-none");
                }
            });
        }
        handlePreview("imageInput", "previewImage");
        handlePreview("imageInput2", "previewImage2");

        // Jodit Editor
        document.addEventListener("DOMContentLoaded", function () {
            const editor = new Jodit('#AboutEditor', {
                height: 400,
                placeholder: "Buraya detaylı içeriği yazmaya başlayın...",
                buttons: "bold,italic,underline,strikethrough,|,ul,ol,|,font,fontsize,paragraph,|,image,table,link,|,align,undo,redo,source"
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}