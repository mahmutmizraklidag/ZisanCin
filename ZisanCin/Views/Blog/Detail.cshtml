@using System.Globalization
@model Blog
@{
	var site = DataRequestModel.SiteSetting;

	ViewData["Title"] = Model?.MetaTitle ?? "Blog";
	ViewData["MetaDescription"] = Model?.MetaDescription ?? site?.MetaDescription ?? "Blog";
	ViewData["MetaKeywords"] = Model?.Keywords ?? site?.Keywords ?? "Blog";
	var trCulture = new CultureInfo("tr-TR");
}
<main class="page-content sm:pt-21.5 pt-16">
<section class="lg:pt-25 lg:pb-10 pt-12.5 pb-5">
	<div class="container">
		<div class="row">
			<div class="w-full mb-7.5">
				<div class="sm:pb-7.5 pb-3.75">
						<h1 class="inline lg:text-4xxl sm:text-3xxl text-2xxl max-w-224 mb-2.5">@Model.Title</h1>
					<div class="sm:mb-7.5 mb-5">
						<ul class="flex flex-wrap items-center gap-2.5">
							@{
									var formattedDate = Model.CreatedAt.ToString("dd MMM yyyy", trCulture);
							}
							<li class="bg-[rgba(var(--primary-rgb),0.1)] text-primary rounded-xxl font-medium text-2xs py-1.25 pr-3.75 pl-5.75 leading-[1.4] relative inline-flex mr-1.25 items-center gap-1 flex-wrap after:absolute after:size-1.5 after:rounded-full after:bg-primary after:left-2.5">@formattedDate</li>
							<li class="inline-flex flex-wrap items-center gap-1.5 sm:text-2xs text-xs font-medium text-secondary py-1.5 px-3">
								<i class="fa-solid fa-user text-xs text-primary mr-2 translate-y-px relative -top-px"></i>
								<a href="blog-grid.html">Zişan CİN</a>
							</li>
							
						</ul>
					</div>
					<div class="sm:rounded-3xl rounded-xxl relative overflow-hidden">
						<img loading="lazy" src="@Url.Content("~/images/blog/img1.webp")" alt="img" class="size-full object-cover">
					</div>
				</div>
				<div class="mb-15 w-full">
					<div class="dz-info">
						<div class="mb-1.25">
                                @Html.Raw(Model.Description)
						</div>
						
						
					</div>
				</div>
				
			</div>
			
		</div>
	</div>
</section>
</main>