@model SiteSetting

@{
    ViewData["Title"] = "Konfigürasyonu Sil";
}

<style>
    .delete-container {
        max-width: 900px;
        margin: auto;
    }

    .warning-card {
        background: #ffffff;
        border-radius: 24px;
        border: none;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .danger-banner {
        background: #fff5f5;
        border-left: 5px solid #e63946;
        padding: 25px;
        border-radius: 12px;
    }

    .info-grid-box {
        background: #fcfcfd;
        border-radius: 16px;
        padding: 25px;
        border: 1px solid #f1f1f1;
    }

    .label-muted {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #adb5bd;
        font-weight: 700;
        margin-bottom: 4px;
        display: block;
    }

    .value-text {
        color: #2b2d42;
        font-weight: 600;
        font-size: 0.95rem;
        margin-bottom: 15px;
    }

    .logo-preview-box {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 16px;
        padding: 40px;
        text-align: center;
        border: 1px solid #dee2e6;
    }

    .action-bar {
        background: #f8f9fa;
        padding: 25px 35px;
        border-top: 1px solid #eee;
    }
</style>

<div class="container py-5 delete-container">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark mb-1">Sistem Ayarlarını Kaldır</h2>
        <p class="text-muted small">Bu işlem sitenizin tüm teknik ve kurumsal kimlik altyapısını silecektir.</p>
    </div>

    <div class="card warning-card">
        <div class="p-4 p-md-5">
            <div class="danger-banner d-flex align-items-start mb-5 shadow-sm">
                <div class="bg-danger text-white rounded-circle p-2 me-3 mt-1 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; flex-shrink: 0;">
                    <i class="bi bi-shield-exclamation fs-4"></i>
                </div>
                <div>
                    <h6 class="mb-1 fw-bold text-danger">KRİTİK UYARI: Sistem Devre Dışı Kalabilir!</h6>
                    <p class="text-muted small mb-0">
                        Bu ayarları sildiğinizde; <strong>SMTP mail gönderimi duracak</strong>, <strong>haritalar yüklenmeyecek</strong> ve <strong>sosyal medya bağlantıları</strong> kaybolacaktır. Bu işlem kesinlikle geri alınamaz.
                    </p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-4">
                    <span class="label-muted mb-2">Marka Logosu</span>
                    <div class="logo-preview-box mb-3">
                        @if (!string.IsNullOrEmpty(Model.Logo))
                        {
                            <img src="/img/@Model.Logo" alt="Site Logo" class="img-fluid" style="max-height: 80px;">
                        }
                        else
                        {
                            <i class="bi bi-image fs-1 opacity-25"></i>
                        }
                    </div>
                    <span class="label-muted">Kayıtlı Başlık</span>
                    <div class="value-text">@Model.MetaTitle</div>
                </div>

                <div class="col-md-8">
                    <div class="info-grid-box">
                        <div class="row">
                            <div class="col-sm-6">
                                <span class="label-muted">İletişim Kanalı</span>
                                <div class="value-text">@Model.Phone <br> <small>@Model.Email</small></div>
                            </div>
                            <div class="col-sm-6">
                                <span class="label-muted">SMTP Sunucusu</span>
                                <div class="value-text text-primary">@Model.SmtpServer <br> <small>Port: @Model.SmtpPort</small></div>
                            </div>
                            <div class="col-12 mt-2">
                                <span class="label-muted">Merkez Adres</span>
                                <div class="value-text small">@Model.Address</div>
                            </div>
                            <div class="col-12">
                                <span class="label-muted">Aktif Sosyal Kanallar</span>
                                <div class="d-flex gap-2 flex-wrap mt-2">
                                    @if (!string.IsNullOrEmpty(Model.Facebook))
                                    {
                                        <i class="bi bi-facebook text-primary"></i>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Instagram))
                                    {
                                        <i class="bi bi-instagram text-danger"></i>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Twitter))
                                    {
                                        <i class="bi bi-twitter-x"></i>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.LinkedIn))
                                    {
                                        <i class="bi bi-linkedin text-primary"></i>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.YouTube))
                                    {
                                        <i class="bi bi-youtube text-danger"></i>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="action-bar d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary fw-bold">
                <i class="bi bi-chevron-left me-1"></i> İptal Et ve Geri Dön
            </a>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-5 py-2 rounded-pill fw-bold shadow-lg">
                    <i class="bi bi-trash3-fill me-2"></i> Konfigürasyonu Kalıcı Olarak Sil
                </button>
            </form>
        </div>
    </div>
</div>