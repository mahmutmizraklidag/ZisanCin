@model ContactForm

@{
    ViewData["Title"] = "Mesajı Sil";
}

<style>
    .delete-container {
        max-width: 800px;
        margin: auto;
    }

    .warning-card {
        background: #ffffff;
        border-radius: 24px;
        border: none;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .danger-banner {
        background: #fff5f5;
        border-left: 5px solid #e63946;
        padding: 20px;
        border-radius: 12px;
    }

    .info-group {
        border-bottom: 1px solid #f1f1f1;
        padding: 12px 0;
    }

        .info-group:last-child {
            border-bottom: none;
        }

    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #adb5bd;
        font-weight: 700;
        margin-bottom: 4px;
        display: block;
    }

    .info-value {
        color: #2b2d42;
        font-weight: 600;
        font-size: 1rem;
    }

    .message-preview {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 20px;
        color: #6c757d;
        font-style: italic;
        border: 1px dashed #dee2e6;
    }

    .action-bar {
        background: #f8f9fa;
        padding: 25px 35px;
        border-top: 1px solid #eee;
    }
</style>

<div class="container py-5 delete-container">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark mb-1">Mesajı Silmek Üzeresiniz</h2>
        <p class="text-muted">Lütfen silmek istediğiniz mesajın bu olduğundan emin olun.</p>
    </div>

    <div class="card warning-card">
        <div class="p-4 p-md-5">
            <div class="danger-banner d-flex align-items-start mb-4">
                <div class="bg-danger text-white rounded-circle p-2 me-3 mt-1 shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; flex-shrink: 0;">
                    <i class="bi bi-trash3-fill fs-5"></i>
                </div>
                <div>
                    <h6 class="mb-1 fw-bold text-danger">Bu işlem geri alınamaz!</h6>
                    <p class="text-muted small mb-0">
                        @Model.Name tarafından gönderilen bu iletişim formu veri tabanından kalıcı olarak silinecek.
                    </p>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6 info-group">
                    <span class="info-label">Gönderen</span>
                    <div class="info-value">@Model.Name</div>
                </div>
                <div class="col-md-6 info-group">
                    <span class="info-label">E-Posta</span>
                    <div class="info-value">@Model.Email</div>
                </div>
                <div class="col-md-6 info-group">
                    <span class="info-label">Telefon</span>
                    <div class="info-value">@(Model.Phone ?? "-")</div>
                </div>
                <div class="col-md-6 info-group">
                    <span class="info-label">Konu</span>
                    <div class="info-value">@Model.Subject</div>
                </div>
            </div>

            <div class="mt-2">
                <span class="info-label mb-2">Mesaj İçeriği</span>
                <div class="message-preview">
                    "@Model.Message"
                </div>
            </div>
        </div>

        <div class="action-bar d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary fw-bold p-0">
                <i class="bi bi-chevron-left"></i> Vazgeç ve Listeye Dön
            </a>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-5 py-2 rounded-pill fw-bold shadow-lg">
                    <i class="bi bi-trash3 me-2"></i> Onayla ve Sil
                </button>
            </form>
        </div>
    </div>
</div>