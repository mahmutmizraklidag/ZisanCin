@model User

@{
    ViewData["Title"] = "Erişimi Kaldır";
}

<style>
    .delete-container {
        max-width: 750px;
        margin: auto;
    }

    .warning-card {
        background: #ffffff;
        border-radius: 24px;
        border: none;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .danger-banner {
        background: #fff5f5;
        border-left: 5px solid #e63946;
        padding: 20px;
        border-radius: 12px;
    }

    .user-info-box {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 25px;
        border: 1px solid #eee;
    }

    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #adb5bd;
        font-weight: 700;
        margin-bottom: 4px;
        display: block;
    }

    .info-value {
        color: #2b2d42;
        font-weight: 600;
        font-size: 1.1rem;
    }

    .password-toggle-btn {
        color: #4361ee;
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        border: none;
        background: none;
        padding: 0;
        margin-left: 10px;
    }

    .action-bar {
        background: #f8f9fa;
        padding: 25px 35px;
        border-top: 1px solid #eee;
    }
</style>

<div class="container py-5 delete-container">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark mb-1">Hesabı Kalıcı Olarak Sil</h2>
        <p class="text-muted small">Bu kullanıcının admin paneline erişimi tamamen kesilecektir.</p>
    </div>

    <div class="card warning-card">
        <div class="p-4 p-md-5">
            <div class="danger-banner d-flex align-items-start mb-5 shadow-sm">
                <div class="bg-danger text-white rounded-circle p-2 me-3 mt-1 d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; flex-shrink: 0;">
                    <i class="bi bi-shield-lock-fill fs-5"></i>
                </div>
                <div>
                    <h6 class="mb-1 fw-bold text-danger">Kritik Güvenlik İşlemi</h6>
                    <p class="text-muted small mb-0">
                        Bu yönetici hesabı silindiğinde, ilgili kişi mevcut kimlik bilgileriyle bir daha sisteme giriş yapamaz.
                    </p>
                </div>
            </div>

            <div class="user-info-box shadow-sm">
                <div class="row g-4">
                    <div class="col-md-6 border-end border-light">
                        <span class="info-label">Kullanıcı Adı</span>
                        <div class="info-value">
                            <i class="bi bi-person-circle text-primary me-2"></i>@Model.Username
                        </div>
                    </div>
                    <div class="col-md-6">
                        <span class="info-label">Erişim Anahtarı</span>
                        <div class="info-value d-flex align-items-center">
                            <span id="passwordField" style="letter-spacing: 2px;">••••••••</span>
                            <button type="button" class="password-toggle-btn" id="togglePassword">
                                <i class="bi bi-eye"></i> Göster
                            </button>
                            <span id="realPassword" class="d-none">@Model.password</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="action-bar d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary fw-bold p-0">
                <i class="bi bi-chevron-left me-1"></i> Vazgeç ve Listeye Dön
            </a>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-5 py-2 rounded-pill fw-bold shadow-lg">
                    <i class="bi bi-trash3-fill me-2"></i> Yetkiyi Kaldır ve Sil
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const togglePassword = document.getElementById("togglePassword");
        const passwordField = document.getElementById("passwordField");
        const realPassword = document.getElementById("realPassword");

        togglePassword.addEventListener("click", function () {
            const icon = this.querySelector("i");
            if (passwordField.innerText.includes("•")) {
                passwordField.innerText = realPassword.innerText;
                passwordField.style.letterSpacing = "0";
                this.innerHTML = '<i class="bi bi-eye-slash"></i> Gizle';
            } else {
                passwordField.innerText = "••••••••";
                passwordField.style.letterSpacing = "2px";
                this.innerHTML = '<i class="bi bi-eye"></i> Göster';
            }
        });
    });
</script>