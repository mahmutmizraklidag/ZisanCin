@model Service

@{
    ViewData["Title"] = "Yeni Hizmet Ekle";
}

<style>
    .form-card {
        background: #fff;
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .nav-pills .nav-link {
        color: #6c757d;
        font-weight: 500;
        padding: 12px 20px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .nav-pills .nav-link.active {
            background-color: #28a745; /* Ekleme sayfası için pozitif yeşil tonu */
            color: #fff;
            box-shadow: 0 4px 12px rgba(40, 167, 69, 0.3);
        }

    .form-control {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #28a745;
            box-shadow: 0 0 0 0.25rem rgba(40, 167, 69, 0.1);
        }

    .upload-zone {
        border: 2px dashed #dee2e6;
        border-radius: 15px;
        padding: 30px;
        text-align: center;
        background: #fdfdfd;
        cursor: pointer;
        transition: 0.3s;
    }

        .upload-zone:hover {
            border-color: #28a745;
            background: #f1fcf4;
        }

    .section-header {
        border-left: 5px solid #28a745;
        padding-left: 15px;
        margin-bottom: 25px;
    }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Yeni Hizmet Tanımla</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Hizmet Portföyü</a></li>
                    <li class="breadcrumb-item active text-success">Yeni Ekle</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
            <i class="bi bi-list-ul me-1"></i> Listeye Dön
        </a>
    </div>

    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 d-none"></div>

        <ul class="nav nav-pills mb-4 gap-2" id="serviceTab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active shadow-sm" data-bs-toggle="pill" data-bs-target="#general-info" type="button">
                    <i class="bi bi-info-circle me-2"></i> Hizmet Bilgileri
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link shadow-sm" data-bs-toggle="pill" data-bs-target="#seo-info" type="button">
                    <i class="bi bi-google me-2"></i> SEO Yapılandırması
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="general-info">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="fw-bold mb-0">Hizmet Detayları</h5>
                            <small class="text-muted">Web sitenizde görünecek ana hizmet bilgileri.</small>
                        </div>
                        <div class="form-check form-switch bg-light p-3 rounded-4 border shadow-sm">
                            <input class="form-check-input" type="checkbox" asp-for="IsHome" style="width: 2.5em; height: 1.2em; cursor: pointer;">
                            <label class="form-check-label fw-bold ms-2 text-success" asp-for="IsHome">Anasayfada Vitrin</label>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-bold">Hizmet Başlığı</label>
                            <input asp-for="Title" class="form-control" placeholder="Örn: Diş İmplant Tedavisi" id="titleInput" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Slug" class="form-label fw-bold">URL Yapısı (Slug)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted">/hizmet/</span>
                                <input asp-for="Slug" class="form-control border-start-0 ps-0" placeholder="hizmet-adi" id="slugInput" />
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Hizmet İçeriği</label>
                            <textarea id="ServiceEditor" asp-for="Description" class="form-control"></textarea>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Hizmet Kapak Görseli</label>
                            <div class="upload-zone shadow-sm" onclick="document.getElementById('imageInput').click()">
                                <i class="bi bi-cloud-arrow-up-fill fs-1 text-success opacity-75"></i>
                                <p class="text-muted mt-2">Görsel seçmek için tıklayın veya sürükleyin</p>
                                <input asp-for="Image" type="file" id="imageInput" class="d-none" />
                            </div>
                            <div class="mt-3 text-center">
                                <img id="previewImage" src="#" alt="Önizleme" class="rounded shadow-sm d-none" style="max-height: 250px; border: 4px solid #fff;" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="seo-info">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Arama Motoru Optimizasyonu</h5>
                        <small class="text-muted">Bu hizmetin Google sonuçlarındaki görünümünü ayarlayın.</small>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="MetaTitle" class="form-label fw-bold">SEO Başlığı (Meta Title)</label>
                            <input asp-for="MetaTitle" class="form-control" placeholder="Maksimum 60 karakter önerilir" />
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Keywords" class="form-label fw-bold">Anahtar Kelimeler</label>
                            <input asp-for="Keywords" class="form-control" placeholder="implant, cerrahi, diş estetiği..." />
                        </div>

                        <div class="col-md-12">
                            <label asp-for="MetaDescription" class="form-label fw-bold">SEO Açıklaması (Meta Description)</label>
                            <textarea asp-for="MetaDescription" class="form-control" rows="3" placeholder="Maksimum 160 karakter önerilir"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 d-flex justify-content-end align-items-center gap-3">
            <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 shadow-lg fw-bold">
                <i class="bi bi-cloud-check me-2"></i> Hizmeti Yayınla
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Görsel Önizleme
        document.getElementById("imageInput").addEventListener("change", function (e) {
            const [file] = e.target.files;
            const preview = document.getElementById("previewImage");
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.classList.remove("d-none");
            }
        });

        // Başlıktan Otomatik Slug Oluşturma
        document.getElementById("titleInput").addEventListener("blur", function() {
            const slugInput = document.getElementById("slugInput");
            if(slugInput.value === "") {
                let title = this.value;
                let slug = title.toLowerCase()
                    .replace(/[^a-z0-9 -]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/-+/g, '-');
                slugInput.value = slug;
            }
        });

        // Jodit
        document.addEventListener("DOMContentLoaded", function () {
            new Jodit('#ServiceEditor', {
                height: 400,
                placeholder: "Hizmet detaylarını buraya yazın...",
                buttons: "bold,italic,underline,strikethrough,|,ul,ol,font,fontsize,paragraph,|,image,table,link,|,align,undo,redo,source"
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}