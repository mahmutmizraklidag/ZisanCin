@model IEnumerable<Slider>

@{
    ViewData["Title"] = "Slider Yönetimi";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.95);
    }

    body {
        background-color: #f0f2f5;
        font-family: 'Inter', sans-serif;
    }

    .admin-card {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }

    .table thead th {
        background-color: transparent;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.05rem;
        font-weight: 700;
        color: #6c757d;
        border-bottom: 1px solid #eee;
        padding: 15px;
    }

    /* Slider Önizleme Görseli */
    .slider-img-container {
        width: 120px;
        height: 60px;
        overflow: hidden;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        border: 2px solid #fff;
        transition: 0.3s ease;
    }

        .slider-img-container:hover {
            transform: scale(1.05);
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }

        .slider-img-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    /* İşlem Butonları */
    .btn-action {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: all 0.2s;
        border: none;
    }

    .btn-edit {
        background: rgba(67, 97, 238, 0.1);
        color: #4361ee;
    }

        .btn-edit:hover {
            background: #4361ee;
            color: #fff;
        }

    .btn-delete {
        background: rgba(230, 57, 70, 0.1);
        color: #e63946;
    }

        .btn-delete:hover {
            background: #e63946;
            color: #fff;
        }

    /* Arama Alanı */
    .search-wrapper {
        position: relative;
    }

        .search-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
        }

        .search-wrapper .form-control {
            padding-left: 40px;
            border-radius: 12px;
            border: 1px solid #e0e0e0;
        }
</style>

<div class="container-fluid py-5 px-4">
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h1 class="h3 fw-bold text-dark mb-1">Slider Yönetimi</h1>
            <p class="text-muted mb-0">Ana sayfa vitrin görsellerini ve geçişlerini buradan yönetin.</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-pill shadow">
                <i class="bi bi-plus-lg me-2"></i> Yeni Slider Ekle
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="admin-card p-3 d-flex align-items-center">
                <div class="bg-info bg-opacity-10 p-3 rounded-circle me-3">
                    <i class="bi bi-images text-info"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold">@Model.Count()</h6>
                    <small class="text-muted">Toplam Görsel</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card admin-card border-0 shadow-lg">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-white rounded-top-4">
            <div class="search-wrapper w-25">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" class="form-control" placeholder="Başlıklarda ara...">
            </div>
            <div class="text-muted small">
                <i class="bi bi-info-circle me-1"></i> Sürükle-bırak sıralama yakında!
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 150px;">Önizleme</th>
                        <th>Slider Başlığı</th>
                        <th class="text-end pe-4">Yönetim</th>
                    </tr>
                </thead>
                <tbody id="blogTable">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="slider-img-container">
                                    @if (!string.IsNullOrEmpty(item.Image))
                                    {
                                        <img src="/img/@item.Image" alt="@item.Title">
                                    }
                                    else
                                    {
                                        <div class="h-100 bg-light d-flex align-items-center justify-content-center text-muted">
                                            <i class="bi bi-image small"></i>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Title</div>
                                <small class="text-muted">ID: #@item.Id</small>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action btn-edit" title="Düzenle">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action btn-delete" title="Sil">
                                        <i class="bi bi-trash3-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-collection display-1 text-muted opacity-25"></i>
                <p class="mt-3 text-muted">Henüz hiç slider eklenmemiş.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById("searchInput").addEventListener("keyup", function () {
            const value = this.value.toLowerCase();
            const rows = document.querySelectorAll("#blogTable tr");
            rows.forEach(row => {
                row.style.display = row.innerText.toLowerCase().includes(value) ? "" : "none";
            });
        });
    </script>
}