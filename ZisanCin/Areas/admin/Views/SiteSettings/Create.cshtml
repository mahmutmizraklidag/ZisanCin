@model SiteSetting

@{
    ViewData["Title"] = "Yeni Site Yapılandırması";
}

<style>
    .form-card {
        background: #fff;
        border-radius: 24px;
        border: none;
        box-shadow: 0 10px 40px rgba(0,0,0,0.04);
    }

    /* Sekme Stilleri */
    .nav-pills .nav-link {
        color: #6c757d;
        font-weight: 600;
        padding: 12px 24px;
        border-radius: 12px;
        transition: all 0.3s ease;
        background: #fff;
        border: 1px solid transparent;
    }

        .nav-pills .nav-link.active {
            background-color: #28a745; /* Ekleme için yeşil tonu */
            color: #fff;
            box-shadow: 0 8px 20px rgba(40, 167, 69, 0.2);
        }

    /* Form Elemanları */
    .form-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #495057;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
    }

        .form-label i {
            margin-right: 8px;
            color: #28a745;
        }

    .form-control {
        border-radius: 12px;
        padding: 12px 16px;
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #28a745;
            box-shadow: 0 0 0 4px rgba(40, 167, 69, 0.08);
        }

    .section-header {
        border-left: 5px solid #28a745;
        padding-left: 15px;
        margin-bottom: 30px;
    }

    .logo-upload-zone {
        border: 2px dashed #dee2e6;
        border-radius: 16px;
        padding: 30px;
        text-align: center;
        background: #fafafa;
        cursor: pointer;
        transition: 0.3s;
    }

        .logo-upload-zone:hover {
            border-color: #28a745;
            background: #f1fcf4;
        }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Site Ayarlarını Oluştur</h2>
            <p class="text-muted small">Sistemin genel konfigürasyonunu buradan başlatın.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Listeye Dön
        </a>
    </div>

    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4 d-none"></div>

        <ul class="nav nav-pills mb-4 gap-2" id="createConfigTab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active shadow-sm" data-bs-toggle="pill" data-bs-target="#basics" type="button">
                    <i class="bi bi-info-circle me-2"></i> Temel & İletişim
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link shadow-sm" data-bs-toggle="pill" data-bs-target="#socials" type="button">
                    <i class="bi bi-share me-2"></i> Sosyal Medya
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link shadow-sm" data-bs-toggle="pill" data-bs-target="#seo-global" type="button">
                    <i class="bi bi-google me-2"></i> SEO & Meta
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link shadow-sm" data-bs-toggle="pill" data-bs-target="#smtp-tech" type="button">
                    <i class="bi bi-shield-lock me-2"></i> Teknik (SMTP)
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="basics">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Kurumsal Kimlik & İletişim</h5>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Phone" class="form-label"><i class="bi bi-telephone"></i> Telefon Numarası</label>
                            <input asp-for="Phone" class="form-control" placeholder="+90 5xx ..." />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label"><i class="bi bi-envelope"></i> Kurumsal E-Posta</label>
                            <input asp-for="Email" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Address" class="form-label"><i class="bi bi-geo-alt"></i> Fiziksel Adres</label>
                            <input asp-for="Address" class="form-control" placeholder="Açık adresinizi buraya yazın..." />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="mapLink" class="form-label"><i class="bi bi-map"></i> Google Haritalar Embed/Link</label>
                            <input asp-for="mapLink" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label"><i class="bi bi-image"></i> Site Logosu</label>
                            <div class="logo-upload-zone" onclick="document.getElementById('imageInput').click()">
                                <i class="bi bi-cloud-arrow-up fs-1 text-muted"></i>
                                <p class="mb-0 text-muted">Logo seçmek için buraya tıklayın (PNG önerilir)</p>
                                <input asp-for="Logo" type="file" id="imageInput" class="d-none" />
                            </div>
                            <div class="mt-3 text-center">
                                <img id="previewImage" src="#" class="img-fluid d-none rounded shadow-sm" style="max-height: 100px;" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="socials">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Sosyal Medya Bağlantıları</h5>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-6"><label asp-for="Facebook" class="form-label"><i class="bi bi-facebook"></i> Facebook</label><input asp-for="Facebook" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="Instagram" class="form-label"><i class="bi bi-instagram"></i> Instagram</label><input asp-for="Instagram" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="Twitter" class="form-label"><i class="bi bi-twitter-x"></i> Twitter</label><input asp-for="Twitter" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="LinkedIn" class="form-label"><i class="bi bi-linkedin"></i> LinkedIn</label><input asp-for="LinkedIn" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="YouTube" class="form-label"><i class="bi bi-youtube"></i> YouTube</label><input asp-for="YouTube" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="YouTubeLink" class="form-label"><i class="bi bi-play-btn"></i> Tanıtım Videosu Linki</label><input asp-for="YouTubeLink" class="form-control" /></div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="seo-global">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Global Arama Motoru Ayarları</h5>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="MetaTitle" class="form-label"><i class="bi bi-search"></i> Site Başlığı (Meta Title)</label>
                            <input asp-for="MetaTitle" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Keywords" class="form-label"><i class="bi bi-hash"></i> Anahtar Kelimeler</label>
                            <input asp-for="Keywords" class="form-control" placeholder="kelime, kelime, kelime..." />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="MetaDescription" class="form-label"><i class="bi bi-card-text"></i> Site Açıklaması</label>
                            <textarea asp-for="MetaDescription" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="smtp-tech">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">E-Posta (SMTP) Sunucu Yapılandırması</h5>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-8"><label asp-for="SmtpServer" class="form-label"><i class="bi bi-server"></i> SMTP Server</label><input asp-for="SmtpServer" class="form-control" /></div>
                        <div class="col-md-4"><label asp-for="SmtpPort" class="form-label"><i class="bi bi-plug"></i> Port</label><input asp-for="SmtpPort" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="SmtpEmail" class="form-label"><i class="bi bi-envelope-at"></i> Gönderen E-Posta</label><input asp-for="SmtpEmail" class="form-control" /></div>
                        <div class="col-md-6"><label asp-for="EmailPassword" class="form-label"><i class="bi bi-key"></i> E-Posta Şifresi</label><input asp-for="EmailPassword" type="password" class="form-control" /></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 mb-5 d-flex justify-content-end align-items-center gap-3">
            <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 shadow-lg fw-bold">
                <i class="bi bi-check2-circle me-2"></i> Konfigürasyonu Kaydet
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Görsel Önizleme
        document.getElementById("imageInput").addEventListener("change", function (e) {
            const [file] = e.target.files;
            const preview = document.getElementById("previewImage");
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.classList.remove("d-none");
            }
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}