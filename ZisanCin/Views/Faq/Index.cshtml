@model IEnumerable<Faq>
@{
	ViewData["Title"] = "SSS";
	ViewData["MetaDescription"] = "Diyetisyen Zişan CİN Sıkça Sorulan Sorular";
	ViewData["MetaKeywords"] = "Diyetisyen Zişan CİN Sıkça Sorulan Sorular";

}
<main class="page-content">

	<div class="lg:min-h-125 md:min-h-100 sm:min-h-87.5 min-h-75 bg-cover bg-center bg-light relative z-1 w-full overflow-hidden flex" style="background-image:url(images/banner/bnr1.webp);">
		<div class="container relative z-1 h-auto table">
			<div class="row">
				<div class="lg:w-2/3">
					<div class="table-cell lg:h-125 md:h-100 sm:h-87.5 h-75 align-middle pt-17.5 pb-5 xl:ps-17.5 max-md:text-center">
						<h1 class="2xxl:text-7xl xl:text-6xxl md:text-[48px] text-4xl font-bold mb-1.25 leading-[1.2] break-word !text-white wow fadeInUp" data-wow-delay="0.2s" data-wow-duration="0.8s">SSS</h1>
						<nav class="wow fadeInUp" data-wow-delay="0.4s" data-wow-duration="0.8s">
							<ul class="inline-block rounded-5xl lg:py-2.5 py-1.5 lg:px-7.5 px-5 bg-white shadow-breadcrumb">
								<li class="inline-block lg:text-base text-sm font-normal capitalize text-primary"><a asp-controller="Hpme" asp-action="Index">Anasayfa</a></li>
								<li class="inline-block lg:text-base text-sm font-normal capitalize text-primary pl-2 relative before:content-['\f101'] before:float-left before:text-primary before:font-bold before:font-['Font_Awesome_5_Free'] before:text-sm before:pr-3 before:top-0.5 before:relative">SSS</li>
							</ul>
						</nav>
					</div>
				</div>
			</div>
			<div class="absolute right-[-2%] bottom-[-2%] float-right max-3xl:w-130 max-lg:hidden">
				<img src="images/banner/background.png" alt="" class="wow fadeInUp" data-wow-delay="0.2s" data-wow-duration="0.8s">
			</div>
		</div>
		<div class="absolute z-9 bottom-[5%] right-[45%] max-xl:hidden"><img class="animate-move1" src="images/banner/item1.png" alt=""></div>
		<div class="absolute z-9 3xl:top-[30%] top-2/5 right-[35%] max-xl:hidden"><img class="animate-move2" src="images/banner/item2.png" alt=""></div>
		<div class="absolute z-9 3xl:bottom-[20%] right-[10%] bottom-[30%] max-xl:hidden"><img class="animate-move3" src="images/banner/item3.png" alt=""></div>
		<div class="absolute z-9 bottom-[20%] 3xl:right-[18%] right-[5%] max-xl:hidden"><img class="animate-move3" src="images/banner/item4.png" alt=""></div>
		<div class="h-full w-25 min-w-25 absolute bottom-0 flex justify-between items-center flex-col py-6.25 px-3.75 left-0 border-r border-white/10 z-1 max-xl:hidden">
			<ul class="flex gap-7.5 [writing-mode:sideways-lr]">
				<li><a class="text-xs font-semibold uppercase text-white tracking-[1px]" href="@DataRequestModel.SiteSetting.Facebook" target="_blank">Facebook</a></li>
				<li><a class="text-xs font-semibold uppercase text-white tracking-[1px]" href="@DataRequestModel.SiteSetting.YouTube" target="_blank">Youtube</a></li>
				<li><a class="text-xs font-semibold uppercase text-white tracking-[1px]" href="@DataRequestModel.SiteSetting.Instagram" target="_blank">Instagram</a></li>
			</ul>
			<a href="javascript:void(0);" class="btn btn-white btn-sm !py-2 !px-4 shadow-btn [writing-mode:sideways-lr] !rounded-2xl">Hadi Başlayalım</a>
		</div>
	</div>

	<section class="2xxl:pt-25 2xxl:pb-17.5 md:pt-17.5 sm:pt-12.5 pt-10 pb-10 bg-white">
		<div class="container">
			<div class="row content-wrapper style-5 items-center">
				<div class="2xl:w-5/12 lg:w-1/2 w-full mb-7.5">
					<div class="relative wow fadeInUp" data-wow-delay="1.0s" data-wow-duration="0.8s">
						<div class="rounded-2xl relative overflow-hidden">
							<img src="images/about/sss.png" alt="" class="w-full">
						</div>
					</div>
				</div>
				<div class="2xl:w-7/12 lg:w-1/2 w-full mb-7.5 self-center">
					<div class="xl:pl-7.5">
						<div class="sm:mb-7.5 mb-5 wow fadeInUp" data-wow-delay="0.2s" data-wow-duration="0.8s">
							<h2 class="2xxl:text-4xxl lg:text-[38px] sm:text-[32px] text-2xxl font-bold capitalize mb-3.75">Sıkça Sorulan Sorular</h2>
						
						</div>
						<div class="myAccordion style-3 mb-8.75 wow fadeInUp" data-wow-delay="0.4s" data-wow-duration="0.8s" id="accordionExample">
							@{
								var index = 0;
							}

							@foreach (var item in Model)
							{
								var isFirst = index == 0;

								<div class="accordion-item">
									<h2 class="accordion-header @(isFirst ? "open" : "")">
										<button class="accordion-button" type="button">
											@item.Question
										</button>
										<span class="arrow @(isFirst ? "active" : "")">
											<i class="icon feather icon-chevron-right [.arrow.active_&]:hidden block"></i>
											<i class="icon feather icon-chevron-down [.arrow.active_&]:block hidden"></i>
										</span>
									</h2>
									<div class="accordion-content @(isFirst ? "show" : "")">
										<div class="content-inner">
											@Html.Raw(item.Answer)
										</div>
									</div>
								</div>

								index++;
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-no-repeat bg-cover bg-center" style="background-image: url(images/background/bg2.png);">
		<div class="container">
			<div class="row">
				<div class="md:w-5/12 w-full order-2 md:order-1 p-0">
					<div class="md:absolute bottom-0 left-0 md:w-1/2 w-full overflow-hidden">
						<img src="images/background/CTA.png" alt="" class="w-full">
					</div>
				</div>
				<div class="md:w-7/12 w-full order-1 md:order-2">
					<div class="2xxl:py-37.5 2xl:py-35 xl:py-30 lg:py-25 py-12.5 md:ml-10">
						<div class="relative z-2">
							<h2 class="2xxl:text-6xxl xl:text-5xxl sm:text-4xxl text-[32px] font-bold capitalize sm:mb-7.5 mb-3.75 !text-white"
								data-wow-delay="0.2s" data-wow-duration="0.8s">
								Hafiflemek Hiç Bu Kadar Kolay Olmamıştı
							</h2>
							<a asp-controller="Contact" asp-action="Index" class="btn btn-lg btn-white group wow fadeInUp" data-wow-delay="0.6s" data-wow-duration="0.8s">
                                Hadi Başlayalım
								<span class="size-11 min-w-11 bg-secondary rounded-2lg text-white inline-flex items-center justify-center -my-2.75 -mr-4.5 ml-3 group-hover:bg-white group-hover:text-heading"><i class="feather icon-arrow-right group-hover:animate-toRightFromLeft"></i></span>
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="absolute animate-move4 h-auto bottom-[10%] right-1/5 max-lg:hidden"><img src="images/banner/item1.png" alt=""></div>
		<div class="absolute animate-move4 h-auto top-[15%] left-[5%] max-lg:hidden"><img src="images/banner/item2.png" alt=""></div>
		<div class="absolute animate-move4 h-auto top-1/5 right-[12%] max-lg:hidden"><img src="images/banner/item3.png" alt=""></div>
	</section>

</main>