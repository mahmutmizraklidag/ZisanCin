@model IEnumerable<About>

@{
    ViewData["Title"] = "Hakkımızda Yönetimi";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<style>
    :root {
        --primary-color: #4361ee;
        --secondary-bg: #f8f9fa;
        --glass-bg: rgba(255, 255, 255, 0.9);
    }

    body {
        background-color: #f0f2f5;
        font-family: 'Inter', sans-serif;
    }

    .admin-card {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 16px;
        transition: all 0.3s ease;
    }

    .table thead th {
        background-color: transparent;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05rem;
        font-weight: 700;
        color: #6c757d;
        border-bottom: 1px solid #eee;
    }

    .image-preview {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        border: 2px solid #fff;
    }

    .search-wrapper {
        position: relative;
    }

        .search-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #adb5bd;
        }

        .search-wrapper .form-control {
            padding-left: 40px;
            border-radius: 10px;
            border: 1px solid #e0e0e0;
            background: #fff;
        }

    .btn-action {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        transition: 0.2s;
    }

        .btn-action:hover {
            transform: translateY(-2px);
        }

    /* Boş durum görseli için */
    .empty-state {
        padding: 40px;
        text-align: center;
        color: #adb5bd;
    }
</style>

<div class="container py-5">
    <div class="row align-items-center mb-5">
        <div class="col-md-6">
            <h1 class="h3 fw-bold text-dark mb-1">Kurumsal Bilgiler</h1>
            <p class="text-muted mb-0">Hakkımızda sayfalarındaki içerikleri buradan yönetebilirsiniz.</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <a asp-action="Create" class="btn btn-primary px-4 py-2 rounded-pill shadow-sm">
                <i class="bi bi-plus-lg me-2"></i> Yeni İcerik Ekle
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="admin-card p-3 shadow-sm border-0 d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                    <i class="bi bi-layers text-primary"></i>
                </div>
                <div>
                    <h6 class="mb-0 fw-bold">@Model.Count()</h6>
                    <small class="text-muted">Toplam Kayıt</small>
                </div>
            </div>
        </div>
    </div>

    <div class="admin-card shadow-lg border-0">
        <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-white rounded-top-4">
            <div class="search-wrapper w-25">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" class="form-control" placeholder="Hızlı ara...">
            </div>
            <div class="dropdown">
                <button class="btn btn-light btn-sm rounded-8 border" type="button">
                    <i class="bi bi-filter me-1"></i> Filtrele
                </button>
            </div>
        </div>

        <div class="table-responsive p-0">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Sayfa Görseli</th>
                        <th>Genel Başlık</th>
                        <th>Ana Sayfa Görseli</th>
                        <th>Ana Sayfa Başlığı</th>
                        <th class="text-end pe-4">Yönetim</th>
                    </tr>
                </thead>
                <tbody id="blogTable">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    @if (!string.IsNullOrEmpty(item.Image))
                                    {
                                        <img src="/img/@item.Image" class="image-preview me-3" alt="">
                                    }
                                    else
                                    {
                                        <div class="image-preview bg-light d-flex align-items-center justify-content-center me-3">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                </div>
                            </td>
                            <td>
                                <span class="fw-bold text-dark">@item.Title</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.HomeImage))
                                {
                                    <img src="/img/@item.HomeImage" class="image-preview" alt="">
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark fw-normal border">Görsel Yok</span>
                                }
                            </td>
                            <td>
                                <div class="text-truncate" style="max-width: 200px;">
                                    @item.HomeTitle
                                </div>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn-action bg-info bg-opacity-10 text-info" title="Düzenle">
                                    <i class="bi bi-pencil-fill"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn-action bg-danger bg-opacity-10 text-danger" title="Sil">
                                    <i class="bi bi-trash3-fill"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-folder-x display-4"></i>
                <p class="mt-2">Henüz içerik eklenmemiş.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Arama fonksiyonu optimizasyonu
        document.getElementById("searchInput").addEventListener("keyup", function () {
            const value = this.value.toLowerCase();
            const rows = document.querySelectorAll("#blogTable tr");

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(value) ? "" : "none";
            });
        });
    </script>
}