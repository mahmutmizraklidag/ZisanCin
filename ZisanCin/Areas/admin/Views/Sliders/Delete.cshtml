@model Slider

@{
    ViewData["Title"] = "Slider Sil";
}

<style>
    .delete-container {
        max-width: 850px;
        margin: auto;
    }

    .warning-card {
        background: #ffffff;
        border-radius: 24px;
        border: none;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .danger-banner {
        background: #fff5f5;
        border-left: 5px solid #e63946;
        padding: 20px;
        border-radius: 12px;
    }

    .slider-info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #adb5bd;
        font-weight: 700;
        margin-bottom: 2px;
        display: block;
    }

    .slider-info-value {
        color: #343a40;
        font-weight: 600;
        font-size: 1.1rem;
        margin-bottom: 15px;
    }

    .slider-preview-box {
        width: 100%;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        border: 1px solid #eee;
        background: #f8f9fa;
    }

        .slider-preview-box img {
            width: 100%;
            height: auto;
            max-height: 350px;
            object-fit: cover;
        }

    .action-bar {
        background: #f8f9fa;
        padding: 25px 35px;
        border-top: 1px solid #eee;
    }
</style>

<div class="container py-5 delete-container">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark mb-1">Slider Kaydını Sil</h2>
        <p class="text-muted">Bu vitrin görseli ana sayfadan kalıcı olarak kaldırılacaktır.</p>
    </div>

    <div class="card warning-card">
        <div class="p-4 p-md-5">
            <div class="danger-banner d-flex align-items-center mb-5 shadow-sm">
                <div class="bg-danger text-white rounded-circle p-2 me-3 d-flex align-items-center justify-content-center shadow-sm" style="width: 50px; height: 50px; flex-shrink: 0;">
                    <i class="bi bi-trash3-fill fs-4"></i>
                </div>
                <div>
                    <h6 class="mb-1 fw-bold text-danger">Bu işlem geri alınamaz!</h6>
                    <p class="text-muted small mb-0">Seçili slider görseli ve üzerindeki metinler veri tabanından tamamen silinecek.</p>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-12">
                    <span class="slider-info-label mb-2">Silinecek Slider Görseli</span>
                    <div class="slider-preview-box mb-4">
                        @if (!string.IsNullOrEmpty(Model.Image))
                        {
                            <img src="/img/@Model.Image" alt="Slider Preview" />
                        }
                        else
                        {
                            <div class="py-5 text-center text-muted">
                                <i class="bi bi-image fs-1 opacity-25"></i>
                                <p class="mt-2">Görsel Bulunamadı</p>
                            </div>
                        }
                    </div>
                </div>

                <div class="col-md-6">
                    <span class="slider-info-label">Slider Başlığı</span>
                    <div class="slider-info-value text-primary">@Model.Title</div>
                </div>
                <div class="col-md-6">
                    <span class="slider-info-label">Alt Açıklama</span>
                    <div class="slider-info-value small fw-normal text-secondary">@(Model.Description ?? "Açıklama girilmemiş")</div>
                </div>
            </div>
        </div>

        <div class="action-bar d-flex justify-content-between align-items-center">
            <a asp-action="Index" class="btn btn-link text-decoration-none text-secondary fw-bold p-0">
                <i class="bi bi-chevron-left me-1"></i> Vazgeç ve Listeye Dön
            </a>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-5 py-2 rounded-pill fw-bold shadow-lg">
                    <i class="bi bi-trash3 me-2"></i> Onayla ve Sil
                </button>
            </form>
        </div>
    </div>
</div>