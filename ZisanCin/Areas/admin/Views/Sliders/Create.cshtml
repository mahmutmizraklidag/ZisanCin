@model Slider

@{
    ViewData["Title"] = "Yeni Slider Ekle";
}

<style>
    .form-card {
        background: #fff;
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .form-control {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #28a745; /* Ekleme sayfası için yeşil tonu */
            box-shadow: 0 0 0 0.25rem rgba(40, 167, 69, 0.1);
        }

    .section-header {
        border-left: 5px solid #28a745;
        padding-left: 15px;
        margin-bottom: 25px;
    }

    .upload-zone {
        border: 2px dashed #dee2e6;
        border-radius: 20px;
        padding: 40px;
        text-align: center;
        background: #fafafa;
        cursor: pointer;
        transition: 0.3s;
    }

        .upload-zone:hover {
            border-color: #28a745;
            background: #f1fcf4;
        }

    .preview-box {
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        background: #fff;
        border: 1px solid #eee;
        display: none;
    }

        .preview-box img {
            width: 100%;
            max-height: 350px;
            object-fit: cover;
        }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Yeni Slider Oluştur</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none text-muted">Slider Yönetimi</a></li>
                    <li class="breadcrumb-item active text-success">Yeni Ekle</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
            <i class="bi bi-list-ul me-1"></i> Listeye Dön
        </a>
    </div>

    <div class="row">
        <div class="col-lg-10 mx-auto">
            <div class="card form-card">
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-4"></div>

                        <div class="section-header">
                            <h5 class="fw-bold mb-0">Görsel Üstü Metinler</h5>
                            <small class="text-muted">Slider üzerinde görünecek başlık ve açıklamayı girin.</small>
                        </div>

                        <div class="row g-4 mb-5">
                            <div class="col-md-12">
                                <label asp-for="Title" class="form-label fw-bold">Ana Başlık</label>
                                <input asp-for="Title" class="form-control form-control-lg" placeholder="Örn: Kalite ve Konforun Adresi" />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Description" class="form-label fw-bold">Alt Açıklama Metni</label>
                                <textarea asp-for="Description" class="form-control" rows="2" placeholder="Kısa bir slogan veya tanıtım yazısı..."></textarea>
                                <span asp-validation-for="Description" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="section-header">
                            <h5 class="fw-bold mb-0">Slider Görseli</h5>
                            <small class="text-muted">Önerilen boyut: 1920x800px (Yatay format)</small>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <div class="upload-zone shadow-sm mb-4" onclick="document.getElementById('imageInput').click()">
                                    <i class="bi bi-images fs-1 text-success opacity-75"></i>
                                    <h6 class="mt-3 fw-bold text-dark">Slider Görselini Seçin</h6>
                                    <p class="text-muted small">Dosya seçmek için tıklayın veya sürükleyin</p>
                                    <input asp-for="Image" type="file" id="imageInput" class="d-none" />
                                </div>
                                <span asp-validation-for="Image" class="text-danger small d-block mb-3"></span>

                                <div id="previewContainer" class="preview-box">
                                    <div class="p-2 bg-light border-bottom d-flex justify-content-between align-items-center">
                                        <small class="fw-bold text-muted ps-2"><i class="bi bi-eye me-1"></i> Görsel Önizlemesi</small>
                                        <span class="badge bg-success rounded-pill">Yeni Seçildi</span>
                                    </div>
                                    <img id="previewImage" src="#" alt="Önizleme" />
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-5 border-top pt-4">
                            <button type="reset" class="btn btn-light rounded-pill px-4 me-2">Formu Sıfırla</button>
                            <button type="submit" class="btn btn-success btn-lg rounded-pill px-5 shadow-lg fw-bold">
                                <i class="bi bi-cloud-upload me-2"></i> Slider'ı Yayınla
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // İyileştirilmiş Görsel Önizleme
        document.getElementById("imageInput").addEventListener("change", function (event) {
            const [file] = event.target.files;
            const preview = document.getElementById("previewImage");
            const container = document.getElementById("previewContainer");

            if (file) {
                preview.src = URL.createObjectURL(file);
                container.style.display = 'block';

                // Sayfayı önizlemeye kaydır (isteğe bağlı)
                container.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            } else {
                container.style.display = 'none';
            }
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}