@model Service

@{
    ViewData["Title"] = "Hizmet Düzenle";
}

<style>
    .form-card {
        background: #fff;
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .nav-pills .nav-link {
        color: #6c757d;
        font-weight: 500;
        padding: 12px 20px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .nav-pills .nav-link.active {
            background-color: #4361ee;
            color: #fff;
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
        }

    .form-control, .form-check-input {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #4361ee;
            box-shadow: 0 0 0 0.25rem rgba(67, 97, 238, 0.1);
        }

    .current-img-preview {
        border-radius: 15px;
        overflow: hidden;
        border: 2px solid #eee;
        transition: 0.3s;
    }

    .section-header {
        border-left: 5px solid #4361ee;
        padding-left: 15px;
        margin-bottom: 25px;
    }

    /* Switch Tarzı Checkbox */
    .form-switch .form-check-input {
        width: 3em;
        height: 1.5em;
        cursor: pointer;
    }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Hizmeti Güncelle</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Hizmet Portföyü</a></li>
                    <li class="breadcrumb-item active">Düzenle</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Vazgeç
        </a>
    </div>

    <form asp-action="Edit" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 d-none"></div>

        <ul class="nav nav-pills mb-4 gap-2" id="serviceTab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active shadow-sm" data-bs-toggle="pill" data-bs-target="#general" type="button">
                    <i class="bi bi-info-circle me-2"></i> Temel Bilgiler
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link shadow-sm" data-bs-toggle="pill" data-bs-target="#seo" type="button">
                    <i class="bi bi-search me-2"></i> SEO Yapılandırması
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="general">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="fw-bold mb-0">Hizmet Detayları</h5>
                            <small class="text-muted">Başlık, içerik ve görsel ayarları.</small>
                        </div>
                        <div class="form-check form-switch bg-light p-3 rounded-4 border">
                            <input class="form-check-input" type="checkbox" asp-for="IsHome">
                            <label class="form-check-label fw-bold ms-2 text-primary" asp-for="IsHome">Anasayfada Göster</label>
                        </div>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label asp-for="Title" class="form-label fw-bold">Hizmet Adı</label>
                            <input asp-for="Title" class="form-control" placeholder="Örn: Profesyonel Kahve Kavurma" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Slug" class="form-label fw-bold">URL (Slug)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0">/hizmet/</span>
                                <input asp-for="Slug" class="form-control border-start-0" placeholder="hizmet-url" />
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">Detaylı Açıklama</label>
                            <textarea id="ServiceEditor" asp-for="Description" class="form-control"></textarea>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Hizmet Görseli</label>
                            <div class="row g-3">
                                @if (!string.IsNullOrEmpty(Model.Image))
                                {
                                    <div class="col-auto">
                                        <div class="current-img-preview shadow-sm">
                                            <img src="/img/@Model.Image" alt="" style="max-height: 180px;" />
                                            <div class="bg-dark text-white text-center small py-1">Mevcut Görsel</div>
                                        </div>
                                    </div>
                                }
                                <div class="col">
                                    <div class="p-4 border-2 border-dashed rounded-4 text-center bg-light">
                                        <i class="bi bi-cloud-arrow-up fs-2 text-muted"></i>
                                        <input asp-for="Image" type="file" class="form-control mt-2" id="imageInput" />
                                        <small class="text-muted d-block mt-2">Yeni bir dosya seçerek mevcut olanı değiştirebilirsiniz.</small>
                                    </div>
                                    <div class="mt-3 text-center">
                                        <img id="previewImage" src="#" class="rounded shadow-sm d-none" style="max-height: 150px;" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="seo">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">SEO ve Arama Motoru Ayarları</h5>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="MetaTitle" class="form-label fw-bold">SEO Başlığı</label>
                            <input asp-for="MetaTitle" class="form-control" />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="Keywords" class="form-label fw-bold">Anahtar Kelimeler</label>
                            <input asp-for="Keywords" class="form-control" placeholder="hizmet, kahve, danışmanlık..." />
                        </div>
                        <div class="col-md-12">
                            <label asp-for="MetaDescription" class="form-label fw-bold">Meta Açıklaması</label>
                            <textarea asp-for="MetaDescription" class="form-control" rows="3"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 d-flex justify-content-end align-items-center gap-3">
            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow-lg fw-bold">
                <i class="bi bi-check-lg me-2"></i> Hizmeti Güncelle
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Görsel Önizleme
        document.getElementById("imageInput").addEventListener("change", function (e) {
            const [file] = e.target.files;
            const preview = document.getElementById("previewImage");
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.classList.remove("d-none");
            }
        });

        // Jodit Editor
        document.addEventListener("DOMContentLoaded", function () {
            new Jodit('#ServiceEditor', {
                height: 450,
                placeholder: "Hizmet içeriğini buraya yazın...",
                buttons: "bold,italic,underline,strikethrough,|,ul,ol,font,fontsize,paragraph,|,image,table,link,|,align,undo,redo,source"
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}