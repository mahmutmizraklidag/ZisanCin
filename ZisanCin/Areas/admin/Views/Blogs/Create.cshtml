@model Blog

@{
    ViewData["Title"] = "Yeni Blog Yazısı";
}

<style>
    .form-card {
        background: #fff;
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .nav-pills .nav-link {
        color: #6c757d;
        font-weight: 500;
        padding: 12px 20px;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

        .nav-pills .nav-link.active {
            background-color: #4361ee;
            color: #fff;
            box-shadow: 0 4px 12px rgba(67, 97, 238, 0.3);
        }

    .form-control {
        border-radius: 10px;
        padding: 12px;
        border: 1px solid #e9ecef;
        background-color: #f8f9fa;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #4361ee;
            box-shadow: 0 0 0 0.25rem rgba(67, 97, 238, 0.1);
        }

    .section-header {
        border-left: 5px solid #4361ee;
        padding-left: 15px;
        margin-bottom: 25px;
    }

    .upload-zone {
        border: 2px dashed #dee2e6;
        border-radius: 15px;
        padding: 30px;
        text-align: center;
        background: #fdfdfd;
        cursor: pointer;
        transition: 0.3s;
    }

        .upload-zone:hover {
            border-color: #4361ee;
            background: #f1f4ff;
        }
</style>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h2 class="fw-bold text-dark mb-1">Yeni Makale Oluştur</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0 small">
                    <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Blog</a></li>
                    <li class="breadcrumb-item active">Yeni Ekle</li>
                </ol>
            </nav>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Listeye Dön
        </a>
    </div>

    <form asp-action="Create" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 d-none"></div>

        <ul class="nav nav-pills mb-4 gap-2" id="blogTab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active shadow-sm" data-bs-toggle="pill" data-bs-target="#content" type="button">
                    <i class="bi bi-file-text me-2"></i> İçerik
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link shadow-sm" data-bs-toggle="pill" data-bs-target="#seo" type="button">
                    <i class="bi bi-search me-2"></i> SEO Ayarları
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="content">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Makale Detayları</h5>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label fw-bold">Yazı Başlığı</label>
                            <input asp-for="Title" class="form-control" placeholder="Etkileyici bir başlık giriniz..." id="titleInput" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="CreatedAt" class="form-label fw-bold">Yayın Tarihi</label>
                            <input asp-for="CreatedAt" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Slug" class="form-label fw-bold">URL (Slug)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted">/blog/</span>
                                <input asp-for="Slug" class="form-control border-start-0 ps-0" placeholder="yazi-url-adresi" id="slugInput" />
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold">İçerik Editörü</label>
                            <textarea id="AboutEditor" asp-for="Description" class="form-control"></textarea>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold">Kapak Görseli</label>
                            <div class="upload-zone" onclick="document.getElementById('imageInput').click()">
                                <i class="bi bi-image fs-1 text-muted"></i>
                                <p class="text-muted mt-2">Görsel seçmek için buraya tıklayın</p>
                                <input asp-for="Image" type="file" id="imageInput" class="d-none" />
                            </div>
                            <div class="mt-3 text-center">
                                <img id="previewImage" src="#" alt="Önizleme" class="rounded shadow-sm d-none" style="max-height: 250px;" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="seo">
                <div class="card form-card p-4 p-md-5">
                    <div class="section-header">
                        <h5 class="fw-bold mb-0">Arama Motoru Görünümü</h5>
                    </div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="MetaTitle" class="form-label fw-bold">Meta Başlık</label>
                            <input asp-for="MetaTitle" class="form-control" placeholder="Google'da görünecek başlık" />
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Keywords" class="form-label fw-bold">Anahtar Kelimeler</label>
                            <input asp-for="Keywords" class="form-control" placeholder="virgül, ile, ayırın" />
                        </div>

                        <div class="col-md-12">
                            <label asp-for="MetaDescription" class="form-label fw-bold">Meta Açıklama</label>
                            <textarea asp-for="MetaDescription" class="form-control" rows="3" placeholder="Makalenin kısa özeti..."></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-5 d-flex justify-content-end align-items-center gap-3">
            <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow">
                <i class="bi bi-check2-all me-2"></i> Yazıyı Yayınla
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Görsel Önizleme
        document.getElementById("imageInput").addEventListener("change", function (e) {
            const [file] = e.target.files;
            const preview = document.getElementById("previewImage");
            if (file) {
                preview.src = URL.createObjectURL(file);
                preview.classList.remove("d-none");
            }
        });

        // Başlıktan Otomatik Slug Oluşturma (Opsiyonel)
        document.getElementById("titleInput").addEventListener("blur", function() {
            const slugInput = document.getElementById("slugInput");
            if(slugInput.value === "") {
                let title = this.value;
                let slug = title.toLowerCase()
                    .replace(/[^a-z0-9 -]/g, '')
                    .replace(/\s+/g, '-')
                    .replace(/-+/g, '-');
                slugInput.value = slug;
            }
        });

        // Jodit
        document.addEventListener("DOMContentLoaded", function () {
            new Jodit('#AboutEditor', {
                height: 450,
                placeholder: "Yazmaya başlayın...",
                buttons: "bold,italic,underline,strikethrough,|,ul,ol,font,fontsize,paragraph,|,image,table,link,|,align,undo,redo,source"
            });
        });
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}