</main>
<style>
	.alert {
		padding: 15px;
		margin-top: 20px;
		border: 1px solid transparent;
		border-radius: 4px;
		display: none;
	}

	.alert-success {
		color: #155724;
		background-color: #d4edda;
		border-color: #c3e6cb;
	}

	.alert-danger {
		color: #721c24;
		background-color: #f8d7da;
		border-color: #f5c6cb;
	}
</style>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script>
	$("#iletisimFormu").submit(function(e) {
	e.preventDefault();

	// Önceki mesajları gizle
	$(".sent-message, .error-message").hide();

	// serialize() formu ve içindeki g-recaptcha-response dahil her şeyi otomatik toplar
	var formData = $(this).serialize();

	$.ajax({
	method: "POST",
	url: "/Contact/Index",
	data: formData,
	success: function(res) {
	if (res.success) {
	$("#iletisimFormu")[0].reset();
	grecaptcha.reset(); // Başarılı gönderimden sonra reCAPTCHA'yı sıfırla
	$(".sent-message").fadeIn().delay(5000).fadeOut();
	} else {
	$(".error-message").html(res.message || "Bir hata oluştu.").fadeIn();
	}
	},
	error: function() {
	$(".error-message").html("Sunucu hatası! Lütfen tekrar deneyin.").fadeIn();
	}
	});
	});
</script>